                      (         lisp.asm):00824         ; emit_a_cased: emit A as one char, applying the printer's case-mode
                      (         lisp.asm):00825         ; fold.  If print_case_mode == 1 and A is in 'A'..'Z', it is folded to
                      (         lisp.asm):00826         ; the corresponding lowercase letter before emit.  Other bytes pass
                      (         lisp.asm):00827         ; through unchanged so digits / punctuation / `<` / `>` / `#` etc. are
                      (         lisp.asm):00828         ; never touched.  Preserves A on return; uses B internally.
0985                  (         lisp.asm):00829         emit_a_cased:
0985 7D4C5B           (         lisp.asm):00830                     tst     print_case_mode
0988 270A             (         lisp.asm):00831                     beq     emit_a              ; mode 0 (upper / default) → no fold
098A 8141             (         lisp.asm):00832                     cmpa    #'A'
098C 2506             (         lisp.asm):00833                     blo     emit_a
098E 815A             (         lisp.asm):00834                     cmpa    #'Z'
0990 2202             (         lisp.asm):00835                     bhi     emit_a
0992 8B20             (         lisp.asm):00836                     adda    #$20            ; 'a' - 'A' = 0x20
                      (         lisp.asm):00837                     ; Fall through to emit_a — but emit_a expects to return A
                      (         lisp.asm):00838                     ; intact.  We've already mutated A; that's fine because
                      (         lisp.asm):00839                     ; callers of emit_a_cased don't read A after.
                      (         lisp.asm):00840         ; emit_a: emit A as one char.  Preserves A; uses B.
0994 3402             (         lisp.asm):00841         emit_a:     pshs    a
