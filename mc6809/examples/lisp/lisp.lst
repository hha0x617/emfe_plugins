     700E             (         lisp.asm):00056         BI_MINUS    equ     $700E
     7010             (         lisp.asm):00057         BI_LT       equ     $7010
     7012             (         lisp.asm):00058         BI_GC       equ     $7012
     7014             (         lisp.asm):00059         BI_MUL      equ     $7014
     7016             (         lisp.asm):00060         BI_CADR     equ     $7016
     7018             (         lisp.asm):00061         BI_CADDR    equ     $7018
     701A             (         lisp.asm):00062         BI_CDDR     equ     $701A
     701C             (         lisp.asm):00063         BI_LENGTH   equ     $701C
     701E             (         lisp.asm):00064         BI_APPEND   equ     $701E
     7020             (         lisp.asm):00065         BI_APPLY    equ     $7020
     7022             (         lisp.asm):00066         BI_LIST     equ     $7022
     7024             (         lisp.asm):00067         BI_PRINT    equ     $7024
     7026             (         lisp.asm):00068         BI_NEWLINE  equ     $7026
     7028             (         lisp.asm):00069         BI_ASSOC    equ     $7028
     702A             (         lisp.asm):00070         BI_GENSYM   equ     $702A
     702C             (         lisp.asm):00071         BI_STRLEN   equ     $702C
     702E             (         lisp.asm):00072         BI_STREQ    equ     $702E
     7030             (         lisp.asm):00073         BI_STRAPP   equ     $7030
     7032             (         lisp.asm):00074         BI_STRREF   equ     $7032
     7034             (         lisp.asm):00075         BI_STR2L    equ     $7034
     7036             (         lisp.asm):00076         BI_L2STR    equ     $7036
     7038             (         lisp.asm):00077         BI_DIV      equ     $7038
     703A             (         lisp.asm):00078         BI_MOD      equ     $703A
     703C             (         lisp.asm):00079         BI_ERROR    equ     $703C
     703E             (         lisp.asm):00080         BI_THROW    equ     $703E
     7040             (         lisp.asm):00081         BI_NUM_EQ   equ     $7040
     7042             (         lisp.asm):00082         BI_CHAR_INT equ     $7042
     7044             (         lisp.asm):00083         BI_INT_CHAR equ     $7044
     7046             (         lisp.asm):00084         BI_CHARP    equ     $7046
     7048             (         lisp.asm):00085         BI_MAKE_VEC equ     $7048
     704A             (         lisp.asm):00086         BI_VEC_LEN  equ     $704A
     704C             (         lisp.asm):00087         BI_VEC_REF  equ     $704C
     704E             (         lisp.asm):00088         BI_VEC_SET  equ     $704E
     7050             (         lisp.asm):00089         BI_VEC_LIST equ     $7050
     7052             (         lisp.asm):00090         BI_LIST_VEC equ     $7052
     7054             (         lisp.asm):00091         BI_VECP     equ     $7054
                      (         lisp.asm):00092         
                      (         lisp.asm):00093         ; Mark-sweep GC — 1-byte-per-pair mark table (simpler than a bitmap, and the
                      (         lisp.asm):00094         ; memory map has 8 KB of unused space at $8000-$9FFF anyway).  PAIR_POOL..
                      (         lisp.asm):00095         ; PAIR_END covers 3072 pairs.
     8000             (         lisp.asm):00096         MARK_TABLE  equ     $8000
     8C00             (         lisp.asm):00097         MARK_TABLE_END equ  $8C00           ; 3072 bytes
                      (         lisp.asm):00098         
     FEFE             (         lisp.asm):00099         RSP_TOP     equ     $FEFE
                      (         lisp.asm):00100         
                      (         lisp.asm):00101         ; --- cold-start ------------------------------------------------------------
                      (         lisp.asm):00102                     org     $0100
0100                  (         lisp.asm):00103         cold:
0100 10CEFEFE         (         lisp.asm):00104                     lds     #RSP_TOP
                      (         lisp.asm):00105                     ; ACIA init: master reset + 8N1 / div-16 / no IRQ
0104 8603             (         lisp.asm):00106                     lda     #$03
0106 B7FF00           (         lisp.asm):00107                     sta     ACIA_SR
0109 8615             (         lisp.asm):00108                     lda     #$15
010B B7FF00           (         lisp.asm):00109                     sta     ACIA_SR
