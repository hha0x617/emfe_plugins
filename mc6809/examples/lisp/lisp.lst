     7030             (         lisp.asm):00073         BI_STRAPP   equ     $7030
     7032             (         lisp.asm):00074         BI_STRREF   equ     $7032
     7034             (         lisp.asm):00075         BI_STR2L    equ     $7034
     7036             (         lisp.asm):00076         BI_L2STR    equ     $7036
     7038             (         lisp.asm):00077         BI_DIV      equ     $7038
     703A             (         lisp.asm):00078         BI_MOD      equ     $703A
     703C             (         lisp.asm):00079         BI_ERROR    equ     $703C
     703E             (         lisp.asm):00080         BI_THROW    equ     $703E
     7040             (         lisp.asm):00081         BI_NUM_EQ   equ     $7040
     7042             (         lisp.asm):00082         BI_CHAR_INT equ     $7042
     7044             (         lisp.asm):00083         BI_INT_CHAR equ     $7044
     7046             (         lisp.asm):00084         BI_CHARP    equ     $7046
     7048             (         lisp.asm):00085         BI_MAKE_VEC equ     $7048
     704A             (         lisp.asm):00086         BI_VEC_LEN  equ     $704A
     704C             (         lisp.asm):00087         BI_VEC_REF  equ     $704C
     704E             (         lisp.asm):00088         BI_VEC_SET  equ     $704E
     7050             (         lisp.asm):00089         BI_VEC_LIST equ     $7050
     7052             (         lisp.asm):00090         BI_LIST_VEC equ     $7052
     7054             (         lisp.asm):00091         BI_VECP     equ     $7054
     7056             (         lisp.asm):00092         BI_LOGAND   equ     $7056
     7058             (         lisp.asm):00093         BI_LOGIOR   equ     $7058
     705A             (         lisp.asm):00094         BI_LOGXOR   equ     $705A
     705C             (         lisp.asm):00095         BI_LOGNOT   equ     $705C
     705E             (         lisp.asm):00096         BI_ASH      equ     $705E
     7060             (         lisp.asm):00097         BI_NUM2STR  equ     $7060
     7062             (         lisp.asm):00098         BI_STR2NUM  equ     $7062
     7064             (         lisp.asm):00099         BI_SYM2STR  equ     $7064
     7066             (         lisp.asm):00100         BI_STR2SYM  equ     $7066
     7068             (         lisp.asm):00101         BI_EVAL     equ     $7068
     706A             (         lisp.asm):00102         BI_RDSTR    equ     $706A
     706C             (         lisp.asm):00103         BI_LOADMEM  equ     $706C
     706E             (         lisp.asm):00104         BI_DISPLAY  equ     $706E
     7070             (         lisp.asm):00105         BI_PUTCHAR  equ     $7070
     7072             (         lisp.asm):00106         BI_RAND     equ     $7072
     7074             (         lisp.asm):00107         BI_SEED     equ     $7074
     7076             (         lisp.asm):00108         BI_TICK     equ     $7076
                      (         lisp.asm):00109         
                      (         lisp.asm):00110         ; Mark-sweep GC — 1-byte-per-pair mark table (simpler than a bitmap, and the
                      (         lisp.asm):00111         ; memory map has 8 KB of unused space at $8000-$9FFF anyway).  PAIR_POOL..
                      (         lisp.asm):00112         ; PAIR_END covers 3072 pairs.
     8000             (         lisp.asm):00113         MARK_TABLE  equ     $8000
     8C00             (         lisp.asm):00114         MARK_TABLE_END equ  $8C00           ; 3072 bytes
                      (         lisp.asm):00115         
     FEFE             (         lisp.asm):00116         RSP_TOP     equ     $FEFE
                      (         lisp.asm):00117         
                      (         lisp.asm):00118         ; --- cold-start ------------------------------------------------------------
                      (         lisp.asm):00119                     org     $0100
0100                  (         lisp.asm):00120         cold:
0100 10CEFEFE         (         lisp.asm):00121                     lds     #RSP_TOP
                      (         lisp.asm):00122                     ; ACIA init: master reset + 8N1 / div-16 / no IRQ
0104 8603             (         lisp.asm):00123                     lda     #$03
0106 B7FF00           (         lisp.asm):00124                     sta     ACIA_SR
0109 8615             (         lisp.asm):00125                     lda     #$15
010B B7FF00           (         lisp.asm):00126                     sta     ACIA_SR
                      (         lisp.asm):00127                     ; Greeting
010E 8E068D           (         lisp.asm):00128                     ldx     #msg_banner
0111 170803           (         lisp.asm):00129                     lbsr    puts_native
                      (         lisp.asm):00130                     ; Init heap pointers and symbol table.
0114 8E4C00           (         lisp.asm):00131                     ldx     #PAIR_POOL
0117 BF4ABA           (         lisp.asm):00132                     stx     pair_next
011A 8E6800           (         lisp.asm):00133                     ldx     #SYM_POOL
011D BF4ABC           (         lisp.asm):00134                     stx     sym_next
0120 8E0000           (         lisp.asm):00135                     ldx     #0
0123 BF4ABE           (         lisp.asm):00136                     stx     sym_list        ; head of symbol linked list
0126 BF4B70           (         lisp.asm):00137                     stx     global_env      ; global environment starts empty (NIL)
0129 BF4B72           (         lisp.asm):00138                     stx     current_env     ; lambda-local env starts empty (NIL)
012C BF4B74           (         lisp.asm):00139                     stx     free_list       ; GC free list empty
012F 8E9000           (         lisp.asm):00140                     ldx     #STR_POOL
0132 BF4B6A           (         lisp.asm):00141                     stx     str_next        ; string allocator
0135 8EB000           (         lisp.asm):00142                     ldx     #INT32_POOL
0138 BF4B6C           (         lisp.asm):00143                     stx     int32_next      ; 32-bit int box allocator
013B 8EA200           (         lisp.asm):00144                     ldx     #VEC_POOL
013E BF4B68           (         lisp.asm):00145                     stx     vec_next        ; vector allocator
0141 8E0000           (         lisp.asm):00146                     ldx     #NIL_VAL
0144 BF4B6E           (         lisp.asm):00147                     stx     int32_free      ; no freed boxes yet
0147 8E3016           (         lisp.asm):00148                     ldx     #catch_stack
014A BF4B64           (         lisp.asm):00149                     stx     catch_sp        ; catch handler stack pointer
                      (         lisp.asm):00150                     ; Seed the PRNG with a non-zero constant.  Callers can
                      (         lisp.asm):00151                     ; (seed n) to re-seed; (seed (tick)) works once tick is
                      (         lisp.asm):00152                     ; wired to the cycle counter.
014D 8EDEAD           (         lisp.asm):00153                     ldx     #$DEAD
0150 BF2C54           (         lisp.asm):00154                     stx     rand_state
0153 8EBEEF           (         lisp.asm):00155                     ldx     #$BEEF
0156 BF2C56           (         lisp.asm):00156                     stx     rand_state+2
                      (         lisp.asm):00157                     ; Pre-intern QUOTE / IF / DEFVAR so eval can recognise them
                      (         lisp.asm):00158                     ; without searching by name each time.
