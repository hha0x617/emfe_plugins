                      (         lisp.asm):00004         ; ---------------------------------------------------------------------------
                      (         lisp.asm):00005         ; Hha Lisp for MC6809 — reader + printer + evaluator + GC + TCO stdlib
                      (         lisp.asm):00006         ;
                      (         lisp.asm):00007         ; Runs under the emfe_plugin_mc6809 environment (MC6850 ACIA at $FF00/$FF01,
                      (         lisp.asm):00008         ; 64 KB RAM).  Classic-Lisp style: defun / T / NIL / 'x .
                      (         lisp.asm):00009         ;
                      (         lisp.asm):00010         ; Value encoding (16-bit):
                      (         lisp.asm):00011         ;   bit0=1: fixnum;       value = (word as i16) >> 1 (15-bit signed)
                      (         lisp.asm):00012         ;   value=$0000: NIL
                      (         lisp.asm):00013         ;   value=$0002: T
                      (         lisp.asm):00014         ;   value in $3000..$5FFF: pair pointer (pool A, 4 bytes/cell)
                      (         lisp.asm):00015         ;   value in $6000..$6FFF: symbol pointer (pool B, var-length)
                      (         lisp.asm):00016         ;
                      (         lisp.asm):00017         ; Phase 1 scope: REPL that reads an S-expression, prints it back,
                      (         lisp.asm):00018         ; with atoms (fixnum/symbol), NIL, T, lists (a b c), and quote 'x → (QUOTE x).
                      (         lisp.asm):00019         ; ---------------------------------------------------------------------------
                      (         lisp.asm):00020         
     FF00             (         lisp.asm):00021         ACIA_SR     equ     $FF00
     FF01             (         lisp.asm):00022         ACIA_DATA   equ     $FF01
                      (         lisp.asm):00023         
     A000             (         lisp.asm):00024         TIB_ADDR    equ     $A000
     0200             (         lisp.asm):00025         TIB_SIZE    equ     512             ; enlarged to fit long stdlib macro bodies
                      (         lisp.asm):00026         
     4C80             (         lisp.asm):00027         PAIR_POOL   equ     $4C80           ; pair pool (moved up to make room for
     6800             (         lisp.asm):00028         PAIR_END    equ     $6800           ; growing code/data region; 7 KB = 1792 cells)
     6800             (         lisp.asm):00029         SYM_POOL    equ     $6800
     7000             (         lisp.asm):00030         SYM_END     equ     $7000           ; exclusive (2 KB sym — fits ≥150 syms)
     7000             (         lisp.asm):00031         BUILTIN_POOL equ    $7000           ; built-in primitive function values
     8000             (         lisp.asm):00032         BUILTIN_END equ     $8000           ; exclusive (stride 2 per ID)
     9000             (         lisp.asm):00033         STR_POOL    equ     $9000           ; string pool
     A000             (         lisp.asm):00034         STR_END     equ     $A000           ; exclusive — 4 KB of string space
     B000             (         lisp.asm):00035         INT32_POOL  equ     $B000           ; 32-bit int box pool (for overflow fixnum)
     C000             (         lisp.asm):00036         INT32_END   equ     $C000           ; exclusive — 4 KB = 1024 boxes × 4 bytes
     8C00             (         lisp.asm):00037         INT32_MARK  equ     $8C00           ; mark bitmap (1024 bits = 128 bytes)
     8C80             (         lisp.asm):00038         INT32_MARK_END equ  $8C80
     8E00             (         lisp.asm):00039         CHAR_BASE   equ     $8E00           ; char value range (tag = CHAR_BASE + 2*code)
     9000             (         lisp.asm):00040         CHAR_END    equ     $9000           ; exclusive (256 chars × 2-byte stride)
     A200             (         lisp.asm):00041         VEC_POOL    equ     $A200           ; vector pool (layout: [len 2B][elem 2B]*)
     B000             (         lisp.asm):00042         VEC_END     equ     $B000           ; exclusive — 3.5 KB (TIB grew to 512 B)
                      (         lisp.asm):00043         
     0000             (         lisp.asm):00044         NIL_VAL     equ     $0000
     0002             (         lisp.asm):00045         T_VAL       equ     $0002
                      (         lisp.asm):00046         
                      (         lisp.asm):00047         ; Built-in IDs — each is BUILTIN_POOL + 2*N so the low bit is never set
                      (         lisp.asm):00048         ; (otherwise print_expr would mis-classify the value as a fixnum).
     7000             (         lisp.asm):00049         BI_CONS     equ     $7000
     7002             (         lisp.asm):00050         BI_CAR      equ     $7002
     7004             (         lisp.asm):00051         BI_CDR      equ     $7004
     7006             (         lisp.asm):00052         BI_ATOM     equ     $7006
     7008             (         lisp.asm):00053         BI_EQ       equ     $7008
     700A             (         lisp.asm):00054         BI_NULL     equ     $700A
     700C             (         lisp.asm):00055         BI_PLUS     equ     $700C
     700E             (         lisp.asm):00056         BI_MINUS    equ     $700E
     7010             (         lisp.asm):00057         BI_LT       equ     $7010
     7012             (         lisp.asm):00058         BI_GC       equ     $7012
     7014             (         lisp.asm):00059         BI_MUL      equ     $7014
     7016             (         lisp.asm):00060         BI_CADR     equ     $7016
     7018             (         lisp.asm):00061         BI_CADDR    equ     $7018
     701A             (         lisp.asm):00062         BI_CDDR     equ     $701A
     701C             (         lisp.asm):00063         BI_LENGTH   equ     $701C
     701E             (         lisp.asm):00064         BI_APPEND   equ     $701E
     7020             (         lisp.asm):00065         BI_APPLY    equ     $7020
     7022             (         lisp.asm):00066         BI_LIST     equ     $7022
     7024             (         lisp.asm):00067         BI_PRINT    equ     $7024
     7026             (         lisp.asm):00068         BI_NEWLINE  equ     $7026
     7028             (         lisp.asm):00069         BI_ASSOC    equ     $7028
     702A             (         lisp.asm):00070         BI_GENSYM   equ     $702A
     702C             (         lisp.asm):00071         BI_STRLEN   equ     $702C
     702E             (         lisp.asm):00072         BI_STREQ    equ     $702E
     7030             (         lisp.asm):00073         BI_STRAPP   equ     $7030
     7032             (         lisp.asm):00074         BI_STRREF   equ     $7032
     7034             (         lisp.asm):00075         BI_STR2L    equ     $7034
     7036             (         lisp.asm):00076         BI_L2STR    equ     $7036
     7038             (         lisp.asm):00077         BI_DIV      equ     $7038
     703A             (         lisp.asm):00078         BI_MOD      equ     $703A
     703C             (         lisp.asm):00079         BI_ERROR    equ     $703C
     703E             (         lisp.asm):00080         BI_THROW    equ     $703E
     7040             (         lisp.asm):00081         BI_NUM_EQ   equ     $7040
     7042             (         lisp.asm):00082         BI_CHAR_INT equ     $7042
     7044             (         lisp.asm):00083         BI_INT_CHAR equ     $7044
     7046             (         lisp.asm):00084         BI_CHARP    equ     $7046
     7048             (         lisp.asm):00085         BI_MAKE_VEC equ     $7048
     704A             (         lisp.asm):00086         BI_VEC_LEN  equ     $704A
     704C             (         lisp.asm):00087         BI_VEC_REF  equ     $704C
     704E             (         lisp.asm):00088         BI_VEC_SET  equ     $704E
     7050             (         lisp.asm):00089         BI_VEC_LIST equ     $7050
     7052             (         lisp.asm):00090         BI_LIST_VEC equ     $7052
     7054             (         lisp.asm):00091         BI_VECP     equ     $7054
     7056             (         lisp.asm):00092         BI_LOGAND   equ     $7056
     7058             (         lisp.asm):00093         BI_LOGIOR   equ     $7058
     705A             (         lisp.asm):00094         BI_LOGXOR   equ     $705A
     705C             (         lisp.asm):00095         BI_LOGNOT   equ     $705C
     705E             (         lisp.asm):00096         BI_ASH      equ     $705E
     7060             (         lisp.asm):00097         BI_NUM2STR  equ     $7060
     7062             (         lisp.asm):00098         BI_STR2NUM  equ     $7062
     7064             (         lisp.asm):00099         BI_SYM2STR  equ     $7064
     7066             (         lisp.asm):00100         BI_STR2SYM  equ     $7066
     7068             (         lisp.asm):00101         BI_EVAL     equ     $7068
     706A             (         lisp.asm):00102         BI_RDSTR    equ     $706A
     706C             (         lisp.asm):00103         BI_LOADMEM  equ     $706C
     706E             (         lisp.asm):00104         BI_DISPLAY  equ     $706E
     7070             (         lisp.asm):00105         BI_PUTCHAR  equ     $7070
     7072             (         lisp.asm):00106         BI_RAND     equ     $7072
     7074             (         lisp.asm):00107         BI_SEED     equ     $7074
     7076             (         lisp.asm):00108         BI_TICK     equ     $7076
     7078             (         lisp.asm):00109         BI_PCASE_GET equ    $7078           ; (print-case) → 0 (upper) or 1 (lower)
     707A             (         lisp.asm):00110         BI_PCASE_SET equ    $707A           ; (set-print-case! n) → n  (n must be 0 or 1)
                      (         lisp.asm):00111         
                      (         lisp.asm):00112         ; Mark-sweep GC — 1-byte-per-pair mark table (simpler than a bitmap, and the
                      (         lisp.asm):00113         ; memory map has 8 KB of unused space at $8000-$9FFF anyway).  PAIR_POOL..
                      (         lisp.asm):00114         ; PAIR_END covers 3072 pairs.
     8000             (         lisp.asm):00115         MARK_TABLE  equ     $8000
     8C00             (         lisp.asm):00116         MARK_TABLE_END equ  $8C00           ; 3072 bytes
                      (         lisp.asm):00117         
     FEFE             (         lisp.asm):00118         RSP_TOP     equ     $FEFE
                      (         lisp.asm):00119         
                      (         lisp.asm):00120         ; --- cold-start ------------------------------------------------------------
                      (         lisp.asm):00121                     org     $0100
0100                  (         lisp.asm):00122         cold:
0100 10CEFEFE         (         lisp.asm):00123                     lds     #RSP_TOP
                      (         lisp.asm):00124                     ; ACIA init: master reset + 8N1 / div-16 / no IRQ
0104 8603             (         lisp.asm):00125                     lda     #$03
0106 B7FF00           (         lisp.asm):00126                     sta     ACIA_SR
0109 8615             (         lisp.asm):00127                     lda     #$15
010B B7FF00           (         lisp.asm):00128                     sta     ACIA_SR
                      (         lisp.asm):00129                     ; Greeting
010E 8E06BC           (         lisp.asm):00130                     ldx     #msg_banner
0111 170852           (         lisp.asm):00131                     lbsr    puts_native
                      (         lisp.asm):00132                     ; Init heap pointers and symbol table.
0114 8E4C80           (         lisp.asm):00133                     ldx     #PAIR_POOL
0117 BF4BB4           (         lisp.asm):00134                     stx     pair_next
011A 8E6800           (         lisp.asm):00135                     ldx     #SYM_POOL
011D BF4BB6           (         lisp.asm):00136                     stx     sym_next
0120 8E0000           (         lisp.asm):00137                     ldx     #0
0123 BF4BB8           (         lisp.asm):00138                     stx     sym_list        ; head of symbol linked list
0126 BF4C71           (         lisp.asm):00139                     stx     global_env      ; global environment starts empty (NIL)
0129 BF4C73           (         lisp.asm):00140                     stx     current_env     ; lambda-local env starts empty (NIL)
012C BF4C75           (         lisp.asm):00141                     stx     free_list       ; GC free list empty
012F 8E9000           (         lisp.asm):00142                     ldx     #STR_POOL
0132 BF4C6B           (         lisp.asm):00143                     stx     str_next        ; string allocator
0135 8EB000           (         lisp.asm):00144                     ldx     #INT32_POOL
0138 BF4C6D           (         lisp.asm):00145                     stx     int32_next      ; 32-bit int box allocator
013B 8EA200           (         lisp.asm):00146                     ldx     #VEC_POOL
013E BF4C69           (         lisp.asm):00147                     stx     vec_next        ; vector allocator
0141 8E0000           (         lisp.asm):00148                     ldx     #NIL_VAL
0144 BF4C6F           (         lisp.asm):00149                     stx     int32_free      ; no freed boxes yet
0147 8E3114           (         lisp.asm):00150                     ldx     #catch_stack
014A BF4C65           (         lisp.asm):00151                     stx     catch_sp        ; catch handler stack pointer
                      (         lisp.asm):00152                     ; Seed the PRNG with a non-zero constant.  Callers can
                      (         lisp.asm):00153                     ; (seed n) to re-seed; (seed (tick)) works once tick is
                      (         lisp.asm):00154                     ; wired to the cycle counter.
014D 8EDEAD           (         lisp.asm):00155                     ldx     #$DEAD
0150 BF2D52           (         lisp.asm):00156                     stx     rand_state
0153 8EBEEF           (         lisp.asm):00157                     ldx     #$BEEF
0156 BF2D54           (         lisp.asm):00158                     stx     rand_state+2
                      (         lisp.asm):00159                     ; Pre-intern QUOTE / IF / DEFVAR so eval can recognise them
                      (         lisp.asm):00160                     ; without searching by name each time.
