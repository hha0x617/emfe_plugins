                      (         lisp.asm):00875         ; ACCEPT — read one line into TIB with echo + BS handling.
                      (         lisp.asm):00876         ; Sets tib_len = count.  Returns when CR/LF received.
                      (         lisp.asm):00877         ; ---------------------------------------------------------------------------
09B7                  (         lisp.asm):00878         accept:
