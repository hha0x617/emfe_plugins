                      (         lisp.asm):06234         ; Phase 7 — stdlib bootstrap.
                      (         lisp.asm):06235         ;
                      (         lisp.asm):06236         ; load_stdlib iterates a ROM-resident table of pointers to null-terminated
                      (         lisp.asm):06237         ; Lisp source strings; for each string it copies into TIB, resets the parser
                      (         lisp.asm):06238         ; state, reads one expression, and evaluates it (discarding the result).
                      (         lisp.asm):06239         ; This is how PROGN/AND/OR/* primitives enable user-mode definitions of
                      (         lisp.asm):06240         ; the Tier-1/Tier-2 standard library functions without bloating the ASM.
                      (         lisp.asm):06241         ; ---------------------------------------------------------------------------
