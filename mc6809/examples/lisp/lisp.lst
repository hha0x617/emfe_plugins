                      (         lisp.asm):06237         ; load_stdlib iterates a ROM-resident table of pointers to null-terminated
                      (         lisp.asm):06238         ; Lisp source strings; for each string it copies into TIB, resets the parser
                      (         lisp.asm):06239         ; state, reads one expression, and evaluates it (discarding the result).
                      (         lisp.asm):06240         ; This is how PROGN/AND/OR/* primitives enable user-mode definitions of
