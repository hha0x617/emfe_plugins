                      (         lisp.asm):04687         ; Phase 7 — stdlib bootstrap.
                      (         lisp.asm):04688         ;
                      (         lisp.asm):04689         ; load_stdlib iterates a ROM-resident table of pointers to null-terminated
                      (         lisp.asm):04690         ; Lisp source strings; for each string it copies into TIB, resets the parser
                      (         lisp.asm):04691         ; state, reads one expression, and evaluates it (discarding the result).
