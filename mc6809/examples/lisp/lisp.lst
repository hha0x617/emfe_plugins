4A3E 10250032         (         lisp.asm):06561                     lblo    gm_ret
4A42 8C7000           (         lisp.asm):06562                     cmpx    #PAIR_END
4A45 1024002B         (         lisp.asm):06563                     lbhs    gm_ret
4A49 3410             (         lisp.asm):06564                     pshs    x               ; save input pair ptr
4A4B 1F10             (         lisp.asm):06565                     tfr     x,d
4A4D 834D60           (         lisp.asm):06566                     subd    #PAIR_POOL
4A50 44               (         lisp.asm):06567                     lsra
4A51 56               (         lisp.asm):06568                     rorb
