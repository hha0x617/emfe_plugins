                      (         lisp.asm):06011         ;
                      (         lisp.asm):06012         ; load_stdlib iterates a ROM-resident table of pointers to null-terminated
                      (         lisp.asm):06013         ; Lisp source strings; for each string it copies into TIB, resets the parser
                      (         lisp.asm):06014         ; state, reads one expression, and evaluates it (discarding the result).
                      (         lisp.asm):06015         ; This is how PROGN/AND/OR/* primitives enable user-mode definitions of
                      (         lisp.asm):06016         ; the Tier-1/Tier-2 standard library functions without bloating the ASM.
