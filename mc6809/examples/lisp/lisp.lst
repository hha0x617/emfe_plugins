0123 BF3416           (         lisp.asm):00119                     stx     sym_list        ; head of symbol linked list
0126 BF34A4           (         lisp.asm):00120                     stx     global_env      ; global environment starts empty (NIL)
0129 BF34A6           (         lisp.asm):00121                     stx     current_env     ; lambda-local env starts empty (NIL)
012C BF34A8           (         lisp.asm):00122                     stx     free_list       ; GC free list empty
012F 8E9000           (         lisp.asm):00123                     ldx     #STR_POOL
