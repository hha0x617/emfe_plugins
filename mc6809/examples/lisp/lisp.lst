                      (         lisp.asm):00809         
                      (         lisp.asm):00810         ; emit_a_cased: emit A as one char, applying the printer's case-mode
                      (         lisp.asm):00811         ; fold.  If print_case_mode == 1 and A is in 'A'..'Z', it is folded to
                      (         lisp.asm):00812         ; the corresponding lowercase letter before emit.  Other bytes pass
                      (         lisp.asm):00813         ; through unchanged so digits / punctuation / `<` / `>` / `#` etc. are
                      (         lisp.asm):00814         ; never touched.  Preserves A on return; uses B internally.
0985                  (         lisp.asm):00815         emit_a_cased:
0985 7D4C5E           (         lisp.asm):00816                     tst     print_case_mode
0988 270A             (         lisp.asm):00817                     beq     emit_a              ; mode 0 (upper / default) → no fold
098A 8141             (         lisp.asm):00818                     cmpa    #'A'
098C 2506             (         lisp.asm):00819                     blo     emit_a
098E 815A             (         lisp.asm):00820                     cmpa    #'Z'
0990 2202             (         lisp.asm):00821                     bhi     emit_a
0992 8B20             (         lisp.asm):00822                     adda    #$20            ; 'a' - 'A' = 0x20
                      (         lisp.asm):00823                     ; Fall through to emit_a — but emit_a expects to return A
                      (         lisp.asm):00824                     ; intact.  We've already mutated A; that's fine because
                      (         lisp.asm):00825                     ; callers of emit_a_cased don't read A after.
                      (         lisp.asm):00826         ; emit_a: emit A as one char.  Preserves A; uses B.
0994 3402             (         lisp.asm):00827         emit_a:     pshs    a
0996 F6FF00           (         lisp.asm):00828         ea_wait:    ldb     ACIA_SR
0999 C502             (         lisp.asm):00829                     bitb    #$02
099B 27F9             (         lisp.asm):00830                     beq     ea_wait
