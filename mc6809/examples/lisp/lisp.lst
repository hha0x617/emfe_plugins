37FB 272D             (         lisp.asm):06246                     beq     ld_done
                      (         lisp.asm):06247                     ; Copy Y's null-terminated bytes into TIB.  Guard against
                      (         lisp.asm):06248                     ; overflow: stop at TIB_SIZE bytes (a too-long source would
                      (         lisp.asm):06249                     ; silently corrupt the vector pool just past TIB_ADDR).
