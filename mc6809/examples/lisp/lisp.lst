                      (         lisp.asm):02634         ;
                      (         lisp.asm):02635         ; Environment model: two chains.
                      (         lisp.asm):02636         ;   current_env — prepended to by lambda-application param binding, captured
                      (         lisp.asm):02637         ;                 by LAMBDA.  Popped when the call returns.
                      (         lisp.asm):02638         ;   global_env  — targeted by DEFVAR / DEFUN (even inside a function body).
                      (         lisp.asm):02639         ; Lookup walks current_env first then falls back to global_env.
                      (         lisp.asm):02640         ; ---------------------------------------------------------------------------
