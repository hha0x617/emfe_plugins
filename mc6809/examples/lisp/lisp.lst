                      (         lisp.asm):00820         ; puts_cased: X -> NUL-terminated string.  Like puts_native but routes
                      (         lisp.asm):00821         ; each byte through emit_a_cased so the printer's case-mode fold
                      (         lisp.asm):00822         ; applies.  Used for `T` / `NIL` / `#<CLOSURE>` / `#<MACRO>` /
                      (         lisp.asm):00823         ; `#<BUILTIN>` so they follow the user's chosen case.  Destroys X, A,
                      (         lisp.asm):00824         ; B.
0977                  (         lisp.asm):00825         puts_cased:
0977 A680             (         lisp.asm):00826                     lda     ,x+
0979 2709             (         lisp.asm):00827                     beq     puts_cased_done
097B 3410             (         lisp.asm):00828                     pshs    x
097D 170005           (         lisp.asm):00829                     lbsr    emit_a_cased
0980 3510             (         lisp.asm):00830                     puls    x
0982 20F3             (         lisp.asm):00831                     bra     puts_cased
0984                  (         lisp.asm):00832         puts_cased_done:
0984 39               (         lisp.asm):00833                     rts
                      (         lisp.asm):00834         
                      (         lisp.asm):00835         ; emit_a_cased: emit A as one char, applying the printer's case-mode
                      (         lisp.asm):00836         ; fold.  If print_case_mode == 1 and A is in 'A'..'Z', it is folded to
                      (         lisp.asm):00837         ; the corresponding lowercase letter before emit.  Other bytes pass
                      (         lisp.asm):00838         ; through unchanged so digits / punctuation / `<` / `>` / `#` etc. are
                      (         lisp.asm):00839         ; never touched.  Preserves A on return; uses B internally.
0985                  (         lisp.asm):00840         emit_a_cased:
0985 7D4D48           (         lisp.asm):00841                     tst     print_case_mode
0988 270A             (         lisp.asm):00842                     beq     emit_a              ; mode 0 (upper / default) → no fold
098A 8141             (         lisp.asm):00843                     cmpa    #'A'
098C 2506             (         lisp.asm):00844                     blo     emit_a
098E 815A             (         lisp.asm):00845                     cmpa    #'Z'
0990 2202             (         lisp.asm):00846                     bhi     emit_a
0992 8B20             (         lisp.asm):00847                     adda    #$20            ; 'a' - 'A' = 0x20
                      (         lisp.asm):00848                     ; Fall through to emit_a — but emit_a expects to return A
                      (         lisp.asm):00849                     ; intact.  We've already mutated A; that's fine because
                      (         lisp.asm):00850                     ; callers of emit_a_cased don't read A after.
                      (         lisp.asm):00851         ; emit_a: emit A as one char.  Preserves A; uses B.
0994 3402             (         lisp.asm):00852         emit_a:     pshs    a
0996 F6FF00           (         lisp.asm):00853         ea_wait:    ldb     ACIA_SR
0999 C502             (         lisp.asm):00854                     bitb    #$02
099B 27F9             (         lisp.asm):00855                     beq     ea_wait
