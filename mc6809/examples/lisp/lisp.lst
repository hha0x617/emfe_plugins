                      (         lisp.asm):06550         ; Phase 6 — mark-sweep garbage collector.
                      (         lisp.asm):06551         ;
                      (         lisp.asm):06552         ; Roots: global_env + current_env.  Because `(gc)` is only invoked from the
                      (         lisp.asm):06553         ; REPL (manually, between expressions), all other scratch variables are
                      (         lisp.asm):06554         ; already stale and need not be traced.
                      (         lisp.asm):06555         ; ---------------------------------------------------------------------------
                      (         lisp.asm):06556         
                      (         lisp.asm):06557         ; gc_mark — recursively mark pair X (and its transitive contents).
                      (         lisp.asm):06558         ; If X is not a pair pointer, returns immediately.
