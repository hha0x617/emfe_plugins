37B8 272D             (         lisp.asm):06195                     beq     ld_done
                      (         lisp.asm):06196                     ; Copy Y's null-terminated bytes into TIB.  Guard against
                      (         lisp.asm):06197                     ; overflow: stop at TIB_SIZE bytes (a too-long source would
                      (         lisp.asm):06198                     ; silently corrupt the vector pool just past TIB_ADDR).
37BA 3410             (         lisp.asm):06199                     pshs    x                   ; save table cursor
37BC 8EA000           (         lisp.asm):06200                     ldx     #TIB_ADDR
37BF CEA200           (         lisp.asm):06201                     ldu     #TIB_ADDR+TIB_SIZE  ; end sentinel (guard against overrun)
