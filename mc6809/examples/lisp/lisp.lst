                      (         lisp.asm):06237         ; + and - work directly on raw values; * and / scale.  Range: -128..127.996
                      (         lisp.asm):06238         ; in steps of 1/256.  (* a b) auto-promotes to int32 so the 16-bit product
                      (         lisp.asm):06239         ; doesn't overflow prematurely.
