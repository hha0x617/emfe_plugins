37C4 2709             (         lisp.asm):06203                     beq     ld_copy_done
37C6 8CA200           (         lisp.asm):06204                     cmpx    #TIB_ADDR+TIB_SIZE
37C9 2404             (         lisp.asm):06205                     bhs     ld_copy_done        ; TIB full — truncate
