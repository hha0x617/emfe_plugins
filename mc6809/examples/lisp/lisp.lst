                      (         lisp.asm):06183         ; Phase 7 — stdlib bootstrap.
                      (         lisp.asm):06184         ;
                      (         lisp.asm):06185         ; load_stdlib iterates a ROM-resident table of pointers to null-terminated
                      (         lisp.asm):06186         ; Lisp source strings; for each string it copies into TIB, resets the parser
                      (         lisp.asm):06187         ; state, reads one expression, and evaluates it (discarding the result).
                      (         lisp.asm):06188         ; This is how PROGN/AND/OR/* primitives enable user-mode definitions of
                      (         lisp.asm):06189         ; the Tier-1/Tier-2 standard library functions without bloating the ASM.
                      (         lisp.asm):06190         ; ---------------------------------------------------------------------------
