                      (         lisp.asm):00004         ; ---------------------------------------------------------------------------
                      (         lisp.asm):00005         ; Hha Lisp for MC6809 — reader + printer + evaluator + GC + TCO stdlib
                      (         lisp.asm):00006         ;
                      (         lisp.asm):00007         ; Runs under the emfe_plugin_mc6809 environment (MC6850 ACIA at $FF00/$FF01,
                      (         lisp.asm):00008         ; 64 KB RAM).  Classic-Lisp style: defun / T / NIL / 'x .
                      (         lisp.asm):00009         ;
                      (         lisp.asm):00010         ; Value encoding (16-bit):
                      (         lisp.asm):00011         ;   bit0=1: fixnum;       value = (word as i16) >> 1 (15-bit signed)
                      (         lisp.asm):00012         ;   value=$0000: NIL
                      (         lisp.asm):00013         ;   value=$0002: T
                      (         lisp.asm):00014         ;   value in $3000..$5FFF: pair pointer (pool A, 4 bytes/cell)
                      (         lisp.asm):00015         ;   value in $6000..$6FFF: symbol pointer (pool B, var-length)
                      (         lisp.asm):00016         ;
                      (         lisp.asm):00017         ; Phase 1 scope: REPL that reads an S-expression, prints it back,
                      (         lisp.asm):00018         ; with atoms (fixnum/symbol), NIL, T, lists (a b c), and quote 'x → (QUOTE x).
                      (         lisp.asm):00019         ; ---------------------------------------------------------------------------
                      (         lisp.asm):00020         
     FF00             (         lisp.asm):00021         ACIA_SR     equ     $FF00
     FF01             (         lisp.asm):00022         ACIA_DATA   equ     $FF01
                      (         lisp.asm):00023         
     A000             (         lisp.asm):00024         TIB_ADDR    equ     $A000
     0200             (         lisp.asm):00025         TIB_SIZE    equ     512             ; enlarged to fit long stdlib macro bodies
                      (         lisp.asm):00026         
     4C00             (         lisp.asm):00027         PAIR_POOL   equ     $4C00           ; pair pool (moved up to make room for
     6800             (         lisp.asm):00028         PAIR_END    equ     $6800           ; growing code/data region; 7 KB = 1792 cells)
     6800             (         lisp.asm):00029         SYM_POOL    equ     $6800
     7000             (         lisp.asm):00030         SYM_END     equ     $7000           ; exclusive (2 KB sym — fits ≥150 syms)
     7000             (         lisp.asm):00031         BUILTIN_POOL equ    $7000           ; built-in primitive function values
     8000             (         lisp.asm):00032         BUILTIN_END equ     $8000           ; exclusive (stride 2 per ID)
     9000             (         lisp.asm):00033         STR_POOL    equ     $9000           ; string pool
     A000             (         lisp.asm):00034         STR_END     equ     $A000           ; exclusive — 4 KB of string space
     B000             (         lisp.asm):00035         INT32_POOL  equ     $B000           ; 32-bit int box pool (for overflow fixnum)
     C000             (         lisp.asm):00036         INT32_END   equ     $C000           ; exclusive — 4 KB = 1024 boxes × 4 bytes
     8C00             (         lisp.asm):00037         INT32_MARK  equ     $8C00           ; mark bitmap (1024 bits = 128 bytes)
     8C80             (         lisp.asm):00038         INT32_MARK_END equ  $8C80
     8E00             (         lisp.asm):00039         CHAR_BASE   equ     $8E00           ; char value range (tag = CHAR_BASE + 2*code)
     9000             (         lisp.asm):00040         CHAR_END    equ     $9000           ; exclusive (256 chars × 2-byte stride)
     A200             (         lisp.asm):00041         VEC_POOL    equ     $A200           ; vector pool (layout: [len 2B][elem 2B]*)
     B000             (         lisp.asm):00042         VEC_END     equ     $B000           ; exclusive — 3.5 KB (TIB grew to 512 B)
                      (         lisp.asm):00043         
     0000             (         lisp.asm):00044         NIL_VAL     equ     $0000
     0002             (         lisp.asm):00045         T_VAL       equ     $0002
                      (         lisp.asm):00046         
                      (         lisp.asm):00047         ; Built-in IDs — each is BUILTIN_POOL + 2*N so the low bit is never set
                      (         lisp.asm):00048         ; (otherwise print_expr would mis-classify the value as a fixnum).
     7000             (         lisp.asm):00049         BI_CONS     equ     $7000
     7002             (         lisp.asm):00050         BI_CAR      equ     $7002
     7004             (         lisp.asm):00051         BI_CDR      equ     $7004
     7006             (         lisp.asm):00052         BI_ATOM     equ     $7006
     7008             (         lisp.asm):00053         BI_EQ       equ     $7008
     700A             (         lisp.asm):00054         BI_NULL     equ     $700A
     700C             (         lisp.asm):00055         BI_PLUS     equ     $700C
     700E             (         lisp.asm):00056         BI_MINUS    equ     $700E
     7010             (         lisp.asm):00057         BI_LT       equ     $7010
     7012             (         lisp.asm):00058         BI_GC       equ     $7012
     7014             (         lisp.asm):00059         BI_MUL      equ     $7014
     7016             (         lisp.asm):00060         BI_CADR     equ     $7016
     7018             (         lisp.asm):00061         BI_CADDR    equ     $7018
     701A             (         lisp.asm):00062         BI_CDDR     equ     $701A
     701C             (         lisp.asm):00063         BI_LENGTH   equ     $701C
     701E             (         lisp.asm):00064         BI_APPEND   equ     $701E
     7020             (         lisp.asm):00065         BI_APPLY    equ     $7020
     7022             (         lisp.asm):00066         BI_LIST     equ     $7022
     7024             (         lisp.asm):00067         BI_PRINT    equ     $7024
