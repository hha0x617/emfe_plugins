37CD 20F3             (         lisp.asm):06207                     bra     ld_copy
37CF                  (         lisp.asm):06208         ld_copy_done:
37CF 1F10             (         lisp.asm):06209                     tfr     x,d
37D1 83A000           (         lisp.asm):06210                     subd    #TIB_ADDR
