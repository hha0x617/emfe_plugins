                      (         lisp.asm):06020         ;
                      (         lisp.asm):06021         ; load_stdlib iterates a ROM-resident table of pointers to null-terminated
                      (         lisp.asm):06022         ; Lisp source strings; for each string it copies into TIB, resets the parser
