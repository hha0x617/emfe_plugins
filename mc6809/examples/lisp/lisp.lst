4A54 C38000           (         lisp.asm):06570                     addd    #MARK_TABLE
4A57 1F01             (         lisp.asm):06571                     tfr     d,x             ; X = &mark[pair_idx]
4A59 6D84             (         lisp.asm):06572                     tst     ,x
4A5B 2615             (         lisp.asm):06573                     bne     gm_already
4A5D C601             (         lisp.asm):06574                     ldb     #1
