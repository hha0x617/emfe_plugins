                      (         lisp.asm):00795         ; puts_cased: X -> NUL-terminated string.  Like puts_native but routes
                      (         lisp.asm):00796         ; each byte through emit_a_cased so the printer's case-mode fold
                      (         lisp.asm):00797         ; applies.  Used for `T` / `NIL` / `#<CLOSURE>` / `#<MACRO>` /
                      (         lisp.asm):00798         ; `#<BUILTIN>` so they follow the user's chosen case.  Destroys X, A,
                      (         lisp.asm):00799         ; B.
0977                  (         lisp.asm):00800         puts_cased:
0977 A680             (         lisp.asm):00801                     lda     ,x+
0979 2709             (         lisp.asm):00802                     beq     puts_cased_done
097B 3410             (         lisp.asm):00803                     pshs    x
097D 170005           (         lisp.asm):00804                     lbsr    emit_a_cased
0980 3510             (         lisp.asm):00805                     puls    x
