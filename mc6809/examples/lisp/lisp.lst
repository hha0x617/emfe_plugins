                      (         lisp.asm):00003         ;
                      (         lisp.asm):00004         ; ---------------------------------------------------------------------------
                      (         lisp.asm):00005         ; Hha Lisp for MC6809 — reader + printer + evaluator + GC + TCO stdlib
                      (         lisp.asm):00006         ;
                      (         lisp.asm):00007         ; Runs under the emfe_plugin_mc6809 environment (MC6850 ACIA at $FF00/$FF01,
                      (         lisp.asm):00008         ; 64 KB RAM).  Classic-Lisp style: defun / T / NIL / 'x .
                      (         lisp.asm):00009         ;
                      (         lisp.asm):00010         ; Value encoding (16-bit):
                      (         lisp.asm):00011         ;   bit0=1: fixnum;       value = (word as i16) >> 1 (15-bit signed)
                      (         lisp.asm):00012         ;   value=$0000: NIL
                      (         lisp.asm):00013         ;   value=$0002: T
                      (         lisp.asm):00014         ;   value in $3000..$5FFF: pair pointer (pool A, 4 bytes/cell)
                      (         lisp.asm):00015         ;   value in $6000..$6FFF: symbol pointer (pool B, var-length)
                      (         lisp.asm):00016         ;
                      (         lisp.asm):00017         ; Phase 1 scope: REPL that reads an S-expression, prints it back,
                      (         lisp.asm):00018         ; with atoms (fixnum/symbol), NIL, T, lists (a b c), and quote 'x → (QUOTE x).
                      (         lisp.asm):00019         ; ---------------------------------------------------------------------------
                      (         lisp.asm):00020         
     FF00             (         lisp.asm):00021         ACIA_SR     equ     $FF00
     FF01             (         lisp.asm):00022         ACIA_DATA   equ     $FF01
                      (         lisp.asm):00023         
     A000             (         lisp.asm):00024         TIB_ADDR    equ     $A000
     0200             (         lisp.asm):00025         TIB_SIZE    equ     512             ; enlarged to fit long stdlib macro bodies
                      (         lisp.asm):00026         
     4C80             (         lisp.asm):00027         PAIR_POOL   equ     $4C80           ; pair pool start (after code+data)
     7000             (         lisp.asm):00028         PAIR_END    equ     $7000           ; exclusive — extends through what was
                      (         lisp.asm):00029                                             ; SYM_POOL ($6800..$6FFF) and the address
                      (         lisp.asm):00030                                             ; range previously reserved for builtin
                      (         lisp.asm):00031                                             ; tag values ($7000..$7FFF).  See
                      (         lisp.asm):00032                                             ; BUILTIN_POOL note below.  9088 bytes
                      (         lisp.asm):00033                                             ; = 2272 cells, up from 1760.
     7000             (         lisp.asm):00034         SYM_POOL    equ     $7000           ; relocated from $6800 — now occupies the
                      (         lisp.asm):00035                                             ; range that used to be the builtin tag
     7E00             (         lisp.asm):00036         SYM_END     equ     $7E00           ; range ($7000..$7FFF).  3.5 KB = ~280 syms
                      (         lisp.asm):00037                                             ; max (stdlib + typical session uses ~115).
     7E00             (         lisp.asm):00038         BUILTIN_POOL equ    $7E00           ; built-in primitive tag values relocated
     7E80             (         lisp.asm):00039         BUILTIN_END equ     $7E80           ; from $7000..$7FFF to $7E00..$7E7F to
                      (         lisp.asm):00040                                             ; free 4 KB of pair / symbol headroom.
                      (         lisp.asm):00041                                             ; Tag values are LOGICAL — no physical RAM
                      (         lisp.asm):00042                                             ; lives in this range, so the move is just
                      (         lisp.asm):00043                                             ; an arithmetic shift of every BI_* equ
                      (         lisp.asm):00044                                             ; (mechanical, ABI-invisible to the host).
                      (         lisp.asm):00045                                             ; 62 entries × 2 bytes = 124 bytes used;
                      (         lisp.asm):00046                                             ; 128 bytes reserved for future primitives.
     9000             (         lisp.asm):00047         STR_POOL    equ     $9000           ; string pool
     A000             (         lisp.asm):00048         STR_END     equ     $A000           ; exclusive — 4 KB of string space
     B000             (         lisp.asm):00049         INT32_POOL  equ     $B000           ; 32-bit int box pool (for overflow fixnum)
     C000             (         lisp.asm):00050         INT32_END   equ     $C000           ; exclusive — 4 KB = 1024 boxes × 4 bytes
     8C00             (         lisp.asm):00051         INT32_MARK  equ     $8C00           ; mark bitmap (1024 bits = 128 bytes)
     8C80             (         lisp.asm):00052         INT32_MARK_END equ  $8C80
     8E00             (         lisp.asm):00053         CHAR_BASE   equ     $8E00           ; char value range (tag = CHAR_BASE + 2*code)
     9000             (         lisp.asm):00054         CHAR_END    equ     $9000           ; exclusive (256 chars × 2-byte stride)
     A200             (         lisp.asm):00055         VEC_POOL    equ     $A200           ; vector pool (layout: [len 2B][elem 2B]*)
     B000             (         lisp.asm):00056         VEC_END     equ     $B000           ; exclusive — 3.5 KB (TIB grew to 512 B)
                      (         lisp.asm):00057         
     0000             (         lisp.asm):00058         NIL_VAL     equ     $0000
     0002             (         lisp.asm):00059         T_VAL       equ     $0002
                      (         lisp.asm):00060         
                      (         lisp.asm):00061         ; Built-in IDs — each is BUILTIN_POOL + 2*N so the low bit is never set
                      (         lisp.asm):00062         ; (otherwise print_expr would mis-classify the value as a fixnum).
     7E00             (         lisp.asm):00063         BI_CONS     equ     $7E00
     7E02             (         lisp.asm):00064         BI_CAR      equ     $7E02
     7E04             (         lisp.asm):00065         BI_CDR      equ     $7E04
     7E06             (         lisp.asm):00066         BI_ATOM     equ     $7E06
     7E08             (         lisp.asm):00067         BI_EQ       equ     $7E08
     7E0A             (         lisp.asm):00068         BI_NULL     equ     $7E0A
     7E0C             (         lisp.asm):00069         BI_PLUS     equ     $7E0C
     7E0E             (         lisp.asm):00070         BI_MINUS    equ     $7E0E
     7E10             (         lisp.asm):00071         BI_LT       equ     $7E10
     7E12             (         lisp.asm):00072         BI_GC       equ     $7E12
     7E14             (         lisp.asm):00073         BI_MUL      equ     $7E14
     7E16             (         lisp.asm):00074         BI_CADR     equ     $7E16
     7E18             (         lisp.asm):00075         BI_CADDR    equ     $7E18
     7E1A             (         lisp.asm):00076         BI_CDDR     equ     $7E1A
     7E1C             (         lisp.asm):00077         BI_LENGTH   equ     $7E1C
     7E1E             (         lisp.asm):00078         BI_APPEND   equ     $7E1E
     7E20             (         lisp.asm):00079         BI_APPLY    equ     $7E20
     7E22             (         lisp.asm):00080         BI_LIST     equ     $7E22
     7E24             (         lisp.asm):00081         BI_PRINT    equ     $7E24
     7E26             (         lisp.asm):00082         BI_NEWLINE  equ     $7E26
     7E28             (         lisp.asm):00083         BI_ASSOC    equ     $7E28
     7E2A             (         lisp.asm):00084         BI_GENSYM   equ     $7E2A
     7E2C             (         lisp.asm):00085         BI_STRLEN   equ     $7E2C
     7E2E             (         lisp.asm):00086         BI_STREQ    equ     $7E2E
     7E30             (         lisp.asm):00087         BI_STRAPP   equ     $7E30
     7E32             (         lisp.asm):00088         BI_STRREF   equ     $7E32
     7E34             (         lisp.asm):00089         BI_STR2L    equ     $7E34
     7E36             (         lisp.asm):00090         BI_L2STR    equ     $7E36
     7E38             (         lisp.asm):00091         BI_DIV      equ     $7E38
     7E3A             (         lisp.asm):00092         BI_MOD      equ     $7E3A
     7E3C             (         lisp.asm):00093         BI_ERROR    equ     $7E3C
     7E3E             (         lisp.asm):00094         BI_THROW    equ     $7E3E
     7E40             (         lisp.asm):00095         BI_NUM_EQ   equ     $7E40
     7E42             (         lisp.asm):00096         BI_CHAR_INT equ     $7E42
     7E44             (         lisp.asm):00097         BI_INT_CHAR equ     $7E44
     7E46             (         lisp.asm):00098         BI_CHARP    equ     $7E46
     7E48             (         lisp.asm):00099         BI_MAKE_VEC equ     $7E48
     7E4A             (         lisp.asm):00100         BI_VEC_LEN  equ     $7E4A
     7E4C             (         lisp.asm):00101         BI_VEC_REF  equ     $7E4C
     7E4E             (         lisp.asm):00102         BI_VEC_SET  equ     $7E4E
     7E50             (         lisp.asm):00103         BI_VEC_LIST equ     $7E50
     7E52             (         lisp.asm):00104         BI_LIST_VEC equ     $7E52
     7E54             (         lisp.asm):00105         BI_VECP     equ     $7E54
     7E56             (         lisp.asm):00106         BI_LOGAND   equ     $7E56
     7E58             (         lisp.asm):00107         BI_LOGIOR   equ     $7E58
     7E5A             (         lisp.asm):00108         BI_LOGXOR   equ     $7E5A
     7E5C             (         lisp.asm):00109         BI_LOGNOT   equ     $7E5C
     7E5E             (         lisp.asm):00110         BI_ASH      equ     $7E5E
     7E60             (         lisp.asm):00111         BI_NUM2STR  equ     $7E60
     7E62             (         lisp.asm):00112         BI_STR2NUM  equ     $7E62
     7E64             (         lisp.asm):00113         BI_SYM2STR  equ     $7E64
     7E66             (         lisp.asm):00114         BI_STR2SYM  equ     $7E66
     7E68             (         lisp.asm):00115         BI_EVAL     equ     $7E68
     7E6A             (         lisp.asm):00116         BI_RDSTR    equ     $7E6A
     7E6C             (         lisp.asm):00117         BI_LOADMEM  equ     $7E6C
     7E6E             (         lisp.asm):00118         BI_DISPLAY  equ     $7E6E
     7E70             (         lisp.asm):00119         BI_PUTCHAR  equ     $7E70
     7E72             (         lisp.asm):00120         BI_RAND     equ     $7E72
     7E74             (         lisp.asm):00121         BI_SEED     equ     $7E74
     7E76             (         lisp.asm):00122         BI_TICK     equ     $7E76
     7E78             (         lisp.asm):00123         BI_PCASE_GET equ    $7E78           ; (print-case) → 0 (upper) or 1 (lower)
     7E7A             (         lisp.asm):00124         BI_PCASE_SET equ    $7E7A           ; (set-print-case! n) → n  (n must be 0 or 1)
                      (         lisp.asm):00125         
                      (         lisp.asm):00126         ; Mark-sweep GC — 1-byte-per-pair mark table (simpler than a bitmap, and the
                      (         lisp.asm):00127         ; memory map has 8 KB of unused space at $8000-$9FFF anyway).  PAIR_POOL..
                      (         lisp.asm):00128         ; PAIR_END covers 3072 pairs.
     8000             (         lisp.asm):00129         MARK_TABLE  equ     $8000
     8C00             (         lisp.asm):00130         MARK_TABLE_END equ  $8C00           ; 3072 bytes
                      (         lisp.asm):00131         
     FEFE             (         lisp.asm):00132         RSP_TOP     equ     $FEFE
                      (         lisp.asm):00133         
                      (         lisp.asm):00134         ; --- cold-start ------------------------------------------------------------
                      (         lisp.asm):00135                     org     $0100
0100                  (         lisp.asm):00136         cold:
0100 10CEFEFE         (         lisp.asm):00137                     lds     #RSP_TOP
                      (         lisp.asm):00138                     ; ACIA init: master reset + 8N1 / div-16 / no IRQ
0104 8603             (         lisp.asm):00139                     lda     #$03
0106 B7FF00           (         lisp.asm):00140                     sta     ACIA_SR
0109 8615             (         lisp.asm):00141                     lda     #$15
010B B7FF00           (         lisp.asm):00142                     sta     ACIA_SR
                      (         lisp.asm):00143                     ; Greeting
010E 8E06BC           (         lisp.asm):00144                     ldx     #msg_banner
0111 170852           (         lisp.asm):00145                     lbsr    puts_native
                      (         lisp.asm):00146                     ; Init heap pointers and symbol table.
0114 8E4C80           (         lisp.asm):00147                     ldx     #PAIR_POOL
0117 BF4BB1           (         lisp.asm):00148                     stx     pair_next
011A 8E7000           (         lisp.asm):00149                     ldx     #SYM_POOL
011D BF4BB3           (         lisp.asm):00150                     stx     sym_next
0120 8E0000           (         lisp.asm):00151                     ldx     #0
0123 BF4BB5           (         lisp.asm):00152                     stx     sym_list        ; head of symbol linked list
0126 BF4C6E           (         lisp.asm):00153                     stx     global_env      ; global environment starts empty (NIL)
0129 BF4C70           (         lisp.asm):00154                     stx     current_env     ; lambda-local env starts empty (NIL)
012C BF4C72           (         lisp.asm):00155                     stx     free_list       ; GC free list empty
012F 8E9000           (         lisp.asm):00156                     ldx     #STR_POOL
0132 BF4C68           (         lisp.asm):00157                     stx     str_next        ; string allocator
0135 8EB000           (         lisp.asm):00158                     ldx     #INT32_POOL
0138 BF4C6A           (         lisp.asm):00159                     stx     int32_next      ; 32-bit int box allocator
013B 8EA200           (         lisp.asm):00160                     ldx     #VEC_POOL
013E BF4C66           (         lisp.asm):00161                     stx     vec_next        ; vector allocator
0141 8E0000           (         lisp.asm):00162                     ldx     #NIL_VAL
0144 BF4C6C           (         lisp.asm):00163                     stx     int32_free      ; no freed boxes yet
0147 8E3111           (         lisp.asm):00164                     ldx     #catch_stack
014A BF4C62           (         lisp.asm):00165                     stx     catch_sp        ; catch handler stack pointer
                      (         lisp.asm):00166                     ; Seed the PRNG with a non-zero constant.  Callers can
                      (         lisp.asm):00167                     ; (seed n) to re-seed; (seed (tick)) works once tick is
                      (         lisp.asm):00168                     ; wired to the cycle counter.
014D 8EDEAD           (         lisp.asm):00169                     ldx     #$DEAD
0150 BF2D4F           (         lisp.asm):00170                     stx     rand_state
0153 8EBEEF           (         lisp.asm):00171                     ldx     #$BEEF
0156 BF2D51           (         lisp.asm):00172                     stx     rand_state+2
                      (         lisp.asm):00173                     ; Pre-intern QUOTE / IF / DEFVAR so eval can recognise them
                      (         lisp.asm):00174                     ; without searching by name each time.
0159 8E06F6           (         lisp.asm):00175                     ldx     #s_quote_lit
015C 170A30           (         lisp.asm):00176                     lbsr    intern
015F BF4BB7           (         lisp.asm):00177                     stx     sym_QUOTE
0162 8E06FC           (         lisp.asm):00178                     ldx     #s_if_lit
0165 170A27           (         lisp.asm):00179                     lbsr    intern
