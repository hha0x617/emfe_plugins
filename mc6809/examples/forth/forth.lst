                      (        forth.asm):00787         ; divmod_core — signed 16/16 → quotient+remainder, used by /, MOD, /MOD.
                      (        forth.asm):00788         ; Entry:  2,U = dividend (a), 0,U = divisor (b)
                      (        forth.asm):00789         ; Exit:   U stack is rewritten as ( rem quot ):   2,U=rem, 0,U=quot
                      (        forth.asm):00790         ;         (a.k.a. -2-slot net push — same cell count as the ( a b ) input)
                      (        forth.asm):00791         ;         U itself is NOT adjusted; callers either return as-is (/MOD) or
                      (        forth.asm):00792         ;         pop one extra cell and overwrite (/, MOD).
                      (        forth.asm):00793         ; Sign rule: truncation toward zero. Quotient sign = sign(a) XOR sign(b).
                      (        forth.asm):00794         ;            Remainder sign follows the dividend (C99 / ANS Forth SM/REM).
                      (        forth.asm):00795         ; Divide-by-zero: leaves rem=a, quot=0 on stack (no trap).
                      (        forth.asm):00796         ; ---------------------------------------------------------------------------
