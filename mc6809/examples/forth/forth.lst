068C 7F0684           (        forth.asm):00959                     clr     dm_signr
068F EC42             (        forth.asm):00960                     ldd     2,u             ; D = a
0691 2A0D             (        forth.asm):00961                     bpl     dm_a_pos
0693 43               (        forth.asm):00962                     coma
0694 53               (        forth.asm):00963                     comb
0695 C30001           (        forth.asm):00964                     addd    #1
