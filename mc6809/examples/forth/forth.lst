                      (        forth.asm):00288         ; Arithmetic / logical primitives — 16-bit signed
                      (        forth.asm):00289         ; ---------------------------------------------------------------------------
                      (        forth.asm):00290                     ; + ( a b -- a+b )
028D 01               (        forth.asm):00291         nfa_ADD     fcb     1
028E 2B               (        forth.asm):00292                     fcc     "+"
028F 027F             (        forth.asm):00293         lnk_ADD     fdb     prev_link
0291 0293             (        forth.asm):00294         cfa_ADD     fdb     code_ADD
     028D             (        forth.asm):00295         prev_link   set     nfa_ADD
0293 ECC1             (        forth.asm):00296         code_ADD:   ldd     ,u++
0295 E3C4             (        forth.asm):00297                     addd    ,u
0297 EDC4             (        forth.asm):00298                     std     ,u
0299 7E0184           (        forth.asm):00299                     jmp     NEXT
                      (        forth.asm):00300         
                      (        forth.asm):00301                     ; - ( a b -- a-b )
029C 01               (        forth.asm):00302         nfa_SUB     fcb     1
029D 2D               (        forth.asm):00303                     fcc     "-"
029E 028D             (        forth.asm):00304         lnk_SUB     fdb     prev_link
02A0 02A2             (        forth.asm):00305         cfa_SUB     fdb     code_SUB
     029C             (        forth.asm):00306         prev_link   set     nfa_SUB
02A2 EC42             (        forth.asm):00307         code_SUB:   ldd     2,u             ; D = a
02A4 A3C4             (        forth.asm):00308                     subd    ,u              ; D = a - b
02A6 3342             (        forth.asm):00309                     leau    2,u
02A8 EDC4             (        forth.asm):00310                     std     ,u
02AA 7E0184           (        forth.asm):00311                     jmp     NEXT
                      (        forth.asm):00312         
                      (        forth.asm):00313                     ; AND ( a b -- a&b )
02AD 03               (        forth.asm):00314         nfa_AND     fcb     3
02AE 414E44           (        forth.asm):00315                     fcc     "AND"
02B1 029C             (        forth.asm):00316         lnk_AND     fdb     prev_link
02B3 02B5             (        forth.asm):00317         cfa_AND     fdb     code_AND
     02AD             (        forth.asm):00318         prev_link   set     nfa_AND
