                      (s/forth/forth.asm):00003         ;
                      (s/forth/forth.asm):00004         ; ---------------------------------------------------------------------------
                      (s/forth/forth.asm):00005         ; Hha Forth for MC6809 — ITC (indirect-threaded) kernel running on the
                      (s/forth/forth.asm):00006         ; emfe_plugin_mc6809 environment (MC6850 ACIA at $FF00/$FF01, 64 KB RAM).
                      (s/forth/forth.asm):00007         ;
                      (s/forth/forth.asm):00008         ; Register conventions:
                      (s/forth/forth.asm):00009         ;   U = data stack pointer (grows downward; TOS at  0,U)
                      (s/forth/forth.asm):00010         ;   S = return stack pointer (grows downward; also holds BSR/JSR frames)
                      (s/forth/forth.asm):00011         ;   X = IP                  (points at next CFA word to execute)
                      (s/forth/forth.asm):00012         ;   Y = W                   (holds CFA during NEXT / DOCOL)
                      (s/forth/forth.asm):00013         ;   D = scratch / arithmetic accumulator
                      (s/forth/forth.asm):00014         ;
                      (s/forth/forth.asm):00015         ; Threading (ITC):
                      (s/forth/forth.asm):00016         ;   CFA cell  = pointer to native code (for primitives) or DOCOL (for colon
                      (s/forth/forth.asm):00017         ;               definitions).
                      (s/forth/forth.asm):00018         ;   NEXT does: Y = *IP++; JMP [,Y]   (indirect through Y)
                      (s/forth/forth.asm):00019         ;
                      (s/forth/forth.asm):00020         ; Memory map:
                      (s/forth/forth.asm):00021         ;   $0100..$1FFF   kernel code + built-in dictionary
                      (s/forth/forth.asm):00022         ;   $2000..$9FFF   user dictionary (HERE grows upward)
                      (s/forth/forth.asm):00023         ;   $A000..$A07F   TIB (terminal input buffer, 128 bytes)
                      (s/forth/forth.asm):00024         ;   $B000..$BFFE   data stack (U starts at $BFFE)
                      (s/forth/forth.asm):00025         ;   $C000..$FEFE   return stack (S starts at $FEFE)
                      (s/forth/forth.asm):00026         ;   $FF00/$FF01    ACIA SR/CR, RDR/TDR
                      (s/forth/forth.asm):00027         ;   $FFFE/$FFFF    reset vector → cold
                      (s/forth/forth.asm):00028         ; ---------------------------------------------------------------------------
                      (s/forth/forth.asm):00029         
                      (s/forth/forth.asm):00030         ; --- equates ---------------------------------------------------------------
     FF00             (s/forth/forth.asm):00031         ACIA_SR     equ     $FF00       ; read: status      write: control
     FF01             (s/forth/forth.asm):00032         ACIA_DATA   equ     $FF01       ; read: RDR         write: TDR
                      (s/forth/forth.asm):00033         
     BFFE             (s/forth/forth.asm):00034         PSP_TOP     equ     $BFFE       ; data stack top (U)
     FEFE             (s/forth/forth.asm):00035         RSP_TOP     equ     $FEFE       ; return stack top (S)
     A000             (s/forth/forth.asm):00036         TIB_ADDR    equ     $A000       ; terminal input buffer
     0080             (s/forth/forth.asm):00037         TIB_SIZE    equ     128
     2000             (s/forth/forth.asm):00038         DICT_START  equ     $2000       ; user dictionary grows from here
                      (s/forth/forth.asm):00039         
     0080             (s/forth/forth.asm):00040         F_IMMED     equ     $80         ; flags: immediate
     0040             (s/forth/forth.asm):00041         F_HIDDEN    equ     $40         ; flags: hidden (smudge)
     001F             (s/forth/forth.asm):00042         F_LENMASK   equ     $1F         ; low 5 bits = name length (max 31)
                      (s/forth/forth.asm):00043         
                      (s/forth/forth.asm):00044         ; Forth VM entry vector — used by INTERPRET to pass control to a word.
                      (s/forth/forth.asm):00045         ; EXECUTE primitive expects TOS = CFA.
                      (s/forth/forth.asm):00046         
                      (s/forth/forth.asm):00047         ; --- cold-start vector -----------------------------------------------------
                      (s/forth/forth.asm):00048                     org     $0100
0100                  (s/forth/forth.asm):00049         cold:
0100 10CEFEFE         (s/forth/forth.asm):00050                     lds     #RSP_TOP            ; return stack
0104 CEBFFE           (s/forth/forth.asm):00051                     ldu     #PSP_TOP            ; data stack
                      (s/forth/forth.asm):00052                     ; ACIA init: master reset then 8N1 / div-16 / no IRQ.
0107 8603             (s/forth/forth.asm):00053                     lda     #$03
0109 B7FF00           (s/forth/forth.asm):00054                     sta     ACIA_SR
010C 8615             (s/forth/forth.asm):00055                     lda     #$15
010E B7FF00           (s/forth/forth.asm):00056                     sta     ACIA_SR
                      (s/forth/forth.asm):00057         
                      (s/forth/forth.asm):00058                     ; Greeting so the user knows the REPL is alive.
0111 8E0130           (s/forth/forth.asm):00059                     ldx     #msg_ready
0114 8D5C             (s/forth/forth.asm):00060                     bsr     puts_native
                      (s/forth/forth.asm):00061                     ; Seed HERE / LATEST / STATE.
0116 8E2000           (s/forth/forth.asm):00062                     ldx     #DICT_START
0119 BF108C           (s/forth/forth.asm):00063                     stx     var_HERE
011C 8E1FD0           (s/forth/forth.asm):00064                     ldx     #last_builtin_link
011F BF1059           (s/forth/forth.asm):00065                     stx     var_LATEST
0122 8E0000           (s/forth/forth.asm):00066                     ldx     #0
0125 BF104C           (s/forth/forth.asm):00067                     stx     var_STATE
                      (s/forth/forth.asm):00068                     ; Enter the Forth VM: IP → boot_code → cfa_QUIT → DOCOL → QUIT body.
0128 8E012E           (s/forth/forth.asm):00069                     ldx     #boot_code
012B 7E0183           (s/forth/forth.asm):00070                     jmp     NEXT
                      (s/forth/forth.asm):00071         
012E 1FD7             (s/forth/forth.asm):00072         boot_code:  fdb     cfa_QUIT
                      (s/forth/forth.asm):00073         
0130 48686120466F7274 (s/forth/forth.asm):00074         msg_ready   fcc     "Hha Forth for MC6809 ready."
     6820666F72204D43
     3638303920726561
     64792E
014B 0D0A             (s/forth/forth.asm):00075                     fcb     $0D,$0A
014D 2863292032303236 (s/forth/forth.asm):00076                     fcc     "(c) 2026 hha0x617 - MIT/Apache-2.0"
     2068686130783631
     37202D204D49542F
     4170616368652D32
     2E30
016F 0D0A00           (s/forth/forth.asm):00077                     fcb     $0D,$0A,0
                      (s/forth/forth.asm):00078         
                      (s/forth/forth.asm):00079         ; Native puts: X -> NUL-terminated string. Uses A, B; preserves X? no,
                      (s/forth/forth.asm):00080         ; destroys X. Used during cold boot only.
0172                  (s/forth/forth.asm):00081         puts_native:
0172 A680             (s/forth/forth.asm):00082                     lda     ,x+
0174 270C             (s/forth/forth.asm):00083                     beq     puts_done
0176 F6FF00           (s/forth/forth.asm):00084         puts_wait:  ldb     ACIA_SR
0179 C502             (s/forth/forth.asm):00085                     bitb    #$02
017B 27F9             (s/forth/forth.asm):00086                     beq     puts_wait
017D B7FF01           (s/forth/forth.asm):00087                     sta     ACIA_DATA
0180 20F0             (s/forth/forth.asm):00088                     bra     puts_native
0182                  (s/forth/forth.asm):00089         puts_done:
0182 39               (s/forth/forth.asm):00090                     rts
                      (s/forth/forth.asm):00091         
                      (s/forth/forth.asm):00092         ; ---------------------------------------------------------------------------
                      (s/forth/forth.asm):00093         ; Inner interpreter — NEXT / DOCOL / EXIT
                      (s/forth/forth.asm):00094         ; ---------------------------------------------------------------------------
0183                  (s/forth/forth.asm):00095         NEXT:
0183 10AE81           (s/forth/forth.asm):00096                     ldy     ,x++            ; W = *IP; IP += 2
0186 6EB4             (s/forth/forth.asm):00097                     jmp     [,y]            ; jump through CFA → code field's code
                      (s/forth/forth.asm):00098         
                      (s/forth/forth.asm):00099         ; DOCOL: enter a colon definition. Called via NEXT when the CFA's contents
                      (s/forth/forth.asm):00100         ; point here. On entry Y = CFA; the body starts at Y+2.
0188                  (s/forth/forth.asm):00101         DOCOL:
0188 3410             (s/forth/forth.asm):00102                     pshs    x               ; push old IP onto return stack
018A 3022             (s/forth/forth.asm):00103                     leax    2,y             ; IP = CFA + 2 (body address)
018C 7E0183           (s/forth/forth.asm):00104                     jmp     NEXT
                      (s/forth/forth.asm):00105         
                      (s/forth/forth.asm):00106         ; DOVAR: code field for VARIABLE. Pushes PFA onto the data stack.
018F                  (s/forth/forth.asm):00107         DOVAR:
018F 3122             (s/forth/forth.asm):00108                     leay    2,y             ; PFA = CFA + 2
0191 10AFC3           (s/forth/forth.asm):00109                     sty     ,--u            ; push PFA as 16-bit cell
0194 7E0183           (s/forth/forth.asm):00110                     jmp     NEXT
                      (s/forth/forth.asm):00111         
                      (s/forth/forth.asm):00112         ; DOCON: code field for CONSTANT. Pushes *PFA onto the data stack.
0197                  (s/forth/forth.asm):00113         DOCON:
0197 EC22             (s/forth/forth.asm):00114                     ldd     2,y             ; D = value stored at PFA
0199 EDC3             (s/forth/forth.asm):00115                     std     ,--u
019B 7E0183           (s/forth/forth.asm):00116                     jmp     NEXT
                      (s/forth/forth.asm):00117         
                      (s/forth/forth.asm):00118         ; DOCREATE: code field for CREATE-d words.  Body layout:
                      (s/forth/forth.asm):00119         ;   CFA+0  → DOCREATE (here)
                      (s/forth/forth.asm):00120         ;   CFA+2  → DOES_ADDR (0 if no DOES>, else address of runtime code)
                      (s/forth/forth.asm):00121         ;   CFA+4  → PFA (user data from ALLOT)
                      (s/forth/forth.asm):00122         ; If DOES_ADDR == 0, push PFA and continue.
                      (s/forth/forth.asm):00123         ; Otherwise push PFA, save caller's IP, and enter the runtime code.
019E                  (s/forth/forth.asm):00124         DOCREATE:
019E EC22             (s/forth/forth.asm):00125                     ldd     2,y             ; D = DOES_ADDR
01A0 270C             (s/forth/forth.asm):00126                     beq     docr_no_does
                      (s/forth/forth.asm):00127                     ; Has DOES> runtime.  Save IP, replace with DOES_ADDR, push PFA.
01A2 3410             (s/forth/forth.asm):00128                     pshs    x               ; save caller's IP on the return stack
01A4 1F01             (s/forth/forth.asm):00129                     tfr     d,x             ; X = DOES_ADDR (new IP)
01A6 3124             (s/forth/forth.asm):00130                     leay    4,y             ; Y = PFA
01A8 10AFC3           (s/forth/forth.asm):00131                     sty     ,--u
01AB 7E0183           (s/forth/forth.asm):00132                     jmp     NEXT
01AE                  (s/forth/forth.asm):00133         docr_no_does:
01AE 3124             (s/forth/forth.asm):00134                     leay    4,y             ; Y = PFA
01B0 10AFC3           (s/forth/forth.asm):00135                     sty     ,--u
01B3 7E0183           (s/forth/forth.asm):00136                     jmp     NEXT
                      (s/forth/forth.asm):00137         
                      (s/forth/forth.asm):00138         ; DOMARKER: code field for MARKER-created words.  PFA layout:
                      (s/forth/forth.asm):00139         ;   PFA+0 : saved LATEST (2 bytes)
                      (s/forth/forth.asm):00140         ;   PFA+2 : saved HERE   (2 bytes)
                      (s/forth/forth.asm):00141         ; Executing the marker restores both, effectively forgetting everything
                      (s/forth/forth.asm):00142         ; defined after (and including) the marker itself.
01B6                  (s/forth/forth.asm):00143         DOMARKER:
01B6 3122             (s/forth/forth.asm):00144                     leay    2,y             ; Y = PFA
01B8 ECA4             (s/forth/forth.asm):00145                     ldd     ,y              ; saved LATEST
01BA FD1059           (s/forth/forth.asm):00146                     std     var_LATEST
01BD EC22             (s/forth/forth.asm):00147                     ldd     2,y             ; saved HERE
01BF FD108C           (s/forth/forth.asm):00148                     std     var_HERE
01C2 7E0183           (s/forth/forth.asm):00149                     jmp     NEXT
                      (s/forth/forth.asm):00150         
                      (s/forth/forth.asm):00151         ; ---------------------------------------------------------------------------
                      (s/forth/forth.asm):00152         ; Built-in dictionary — linked list grows from `last_builtin_link`, each
                      (s/forth/forth.asm):00153         ; entry has:
                      (s/forth/forth.asm):00154         ;
                      (s/forth/forth.asm):00155         ;     +0  flags+length byte
                      (s/forth/forth.asm):00156         ;     +1  name bytes (len bytes)
                      (s/forth/forth.asm):00157         ;     +N  link field (2 bytes, big-endian — pointer to previous entry's
                      (s/forth/forth.asm):00158         ;         flags byte, i.e. NFA of previous word)
                      (s/forth/forth.asm):00159         ;     +N+2  CFA  (2 bytes — for primitives: address of code;
                      (s/forth/forth.asm):00160         ;                        for colon defs: address of DOCOL)
                      (s/forth/forth.asm):00161         ;     +N+4  PFA  (body — only for non-primitives)
                      (s/forth/forth.asm):00162         ;
                      (s/forth/forth.asm):00163         ; The `WORD` macro below lays out a primitive header. A secondary macro lays
                      (s/forth/forth.asm):00164         ; out a colon definition header.
                      (s/forth/forth.asm):00165         ; ---------------------------------------------------------------------------
                      (s/forth/forth.asm):00166         
                      (s/forth/forth.asm):00167         ; Each primitive's header starts with a label for the flags/length byte
                      (s/forth/forth.asm):00168         ; (the NFA), followed by name+link+CFA. We emit them with inline .fcb/.fdb.
                      (s/forth/forth.asm):00169         
                      (s/forth/forth.asm):00170         ; link anchor: NULL terminator at the bottom of the chain
     0000             (s/forth/forth.asm):00171         prev_link   set     0
                      (s/forth/forth.asm):00172         
                      (s/forth/forth.asm):00173                     ; -- primitive: EXIT ( -- )  restore IP from R stack ------------
01C5 04               (s/forth/forth.asm):00174         nfa_EXIT    fcb     4
01C6 45584954         (s/forth/forth.asm):00175                     fcc     "EXIT"
01CA 0000             (s/forth/forth.asm):00176         lnk_EXIT    fdb     prev_link
01CC 01CE             (s/forth/forth.asm):00177         cfa_EXIT    fdb     code_EXIT
     01C5             (s/forth/forth.asm):00178         prev_link   set     nfa_EXIT
                      (s/forth/forth.asm):00179         
01CE 3510             (s/forth/forth.asm):00180         code_EXIT:  puls    x               ; IP = saved IP
01D0 7E0183           (s/forth/forth.asm):00181                     jmp     NEXT
                      (s/forth/forth.asm):00182         
                      (s/forth/forth.asm):00183                     ; -- primitive: (LIT) — inline literal --------------------------
01D3 05               (s/forth/forth.asm):00184         nfa_LIT     fcb     5
01D4 284C495429       (s/forth/forth.asm):00185                     fcc     "(LIT)"
01D9 01C5             (s/forth/forth.asm):00186         lnk_LIT     fdb     prev_link
01DB 01DD             (s/forth/forth.asm):00187         cfa_LIT     fdb     code_LIT
     01D3             (s/forth/forth.asm):00188         prev_link   set     nfa_LIT
                      (s/forth/forth.asm):00189         
01DD EC81             (s/forth/forth.asm):00190         code_LIT:   ldd     ,x++            ; D = *IP++; IP advanced past the cell
01DF EDC3             (s/forth/forth.asm):00191                     std     ,--u
01E1 7E0183           (s/forth/forth.asm):00192                     jmp     NEXT
                      (s/forth/forth.asm):00193         
                      (s/forth/forth.asm):00194                     ; -- primitive: (0BRANCH) — branch if TOS == 0 ------------------
01E4 09               (s/forth/forth.asm):00195         nfa_0BR     fcb     9
01E5 28304252414E4348 (s/forth/forth.asm):00196                     fcc     "(0BRANCH)"
     29
01EE 01D3             (s/forth/forth.asm):00197         lnk_0BR     fdb     prev_link
01F0 01F2             (s/forth/forth.asm):00198         cfa_0BR     fdb     code_0BR
     01E4             (s/forth/forth.asm):00199         prev_link   set     nfa_0BR
                      (s/forth/forth.asm):00200         
01F2 ECC1             (s/forth/forth.asm):00201         code_0BR:   ldd     ,u++            ; pop condition
01F4 10830000         (s/forth/forth.asm):00202                     cmpd    #0
01F8 2705             (s/forth/forth.asm):00203                     beq     take_0br
01FA 3002             (s/forth/forth.asm):00204                     leax    2,x             ; skip offset, don't branch
01FC 7E0183           (s/forth/forth.asm):00205                     jmp     NEXT
01FF EC84             (s/forth/forth.asm):00206         take_0br:   ldd     ,x              ; D = branch offset (signed, cell-relative)
0201 308B             (s/forth/forth.asm):00207                     leax    d,x             ; IP += offset
0203 7E0183           (s/forth/forth.asm):00208                     jmp     NEXT
                      (s/forth/forth.asm):00209         
                      (s/forth/forth.asm):00210                     ; -- primitive: (BRANCH) — unconditional branch -----------------
0206 08               (s/forth/forth.asm):00211         nfa_BR      fcb     8
0207 284252414E434829 (s/forth/forth.asm):00212                     fcc     "(BRANCH)"
020F 01E4             (s/forth/forth.asm):00213         lnk_BR      fdb     prev_link
0211 0213             (s/forth/forth.asm):00214         cfa_BR      fdb     code_BR
     0206             (s/forth/forth.asm):00215         prev_link   set     nfa_BR
                      (s/forth/forth.asm):00216         
0213 EC84             (s/forth/forth.asm):00217         code_BR:    ldd     ,x
0215 308B             (s/forth/forth.asm):00218                     leax    d,x
0217 7E0183           (s/forth/forth.asm):00219                     jmp     NEXT
                      (s/forth/forth.asm):00220         
                      (s/forth/forth.asm):00221                     ; -- primitive: EXECUTE ( xt -- ) -------------------------------
021A 07               (s/forth/forth.asm):00222         nfa_EXEC    fcb     7
021B 45584543555445   (s/forth/forth.asm):00223                     fcc     "EXECUTE"
0222 0206             (s/forth/forth.asm):00224         lnk_EXEC    fdb     prev_link
0224 0226             (s/forth/forth.asm):00225         cfa_EXEC    fdb     code_EXEC
     021A             (s/forth/forth.asm):00226         prev_link   set     nfa_EXEC
                      (s/forth/forth.asm):00227         
0226 10AEC1           (s/forth/forth.asm):00228         code_EXEC:  ldy     ,u++            ; Y = CFA popped from data stack
0229 6EB4             (s/forth/forth.asm):00229                     jmp     [,y]
                      (s/forth/forth.asm):00230         
                      (s/forth/forth.asm):00231         ; ---------------------------------------------------------------------------
                      (s/forth/forth.asm):00232         ; Stack primitives
                      (s/forth/forth.asm):00233         ; ---------------------------------------------------------------------------
                      (s/forth/forth.asm):00234                     ; DUP ( a -- a a )
022B 03               (s/forth/forth.asm):00235         nfa_DUP     fcb     3
