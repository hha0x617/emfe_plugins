                      (        forth.asm):00003         ;
                      (        forth.asm):00004         ; ---------------------------------------------------------------------------
                      (        forth.asm):00005         ; Hha Forth for MC6809 — ITC (indirect-threaded) kernel running on the
                      (        forth.asm):00006         ; emfe_plugin_mc6809 environment (MC6850 ACIA at $FF00/$FF01, 64 KB RAM).
                      (        forth.asm):00007         ;
                      (        forth.asm):00008         ; Register conventions:
                      (        forth.asm):00009         ;   U = data stack pointer (grows downward; TOS at  0,U)
                      (        forth.asm):00010         ;   S = return stack pointer (grows downward; also holds BSR/JSR frames)
                      (        forth.asm):00011         ;   X = IP                  (points at next CFA word to execute)
                      (        forth.asm):00012         ;   Y = W                   (holds CFA during NEXT / DOCOL)
                      (        forth.asm):00013         ;   D = scratch / arithmetic accumulator
                      (        forth.asm):00014         ;
                      (        forth.asm):00015         ; Threading (ITC):
                      (        forth.asm):00016         ;   CFA cell  = pointer to native code (for primitives) or DOCOL (for colon
                      (        forth.asm):00017         ;               definitions).
                      (        forth.asm):00018         ;   NEXT does: Y = *IP++; JMP [,Y]   (indirect through Y)
                      (        forth.asm):00019         ;
                      (        forth.asm):00020         ; Memory map:
                      (        forth.asm):00021         ;   $0100..$1FFF   kernel code + built-in dictionary
                      (        forth.asm):00022         ;   $2000..$9FFF   user dictionary (HERE grows upward)
                      (        forth.asm):00023         ;   $A000..$A07F   TIB (terminal input buffer, 128 bytes)
                      (        forth.asm):00024         ;   $B000..$BFFE   data stack (U starts at $BFFE)
                      (        forth.asm):00025         ;   $C000..$FEFE   return stack (S starts at $FEFE)
                      (        forth.asm):00026         ;   $FF00/$FF01    ACIA SR/CR, RDR/TDR
                      (        forth.asm):00027         ;   $FFFE/$FFFF    reset vector → cold
                      (        forth.asm):00028         ; ---------------------------------------------------------------------------
                      (        forth.asm):00029         
                      (        forth.asm):00030         ; --- equates ---------------------------------------------------------------
     FF00             (        forth.asm):00031         ACIA_SR     equ     $FF00       ; read: status      write: control
     FF01             (        forth.asm):00032         ACIA_DATA   equ     $FF01       ; read: RDR         write: TDR
                      (        forth.asm):00033         
     BFFE             (        forth.asm):00034         PSP_TOP     equ     $BFFE       ; data stack top (U)
     FEFE             (        forth.asm):00035         RSP_TOP     equ     $FEFE       ; return stack top (S)
     A000             (        forth.asm):00036         TIB_ADDR    equ     $A000       ; terminal input buffer
     0080             (        forth.asm):00037         TIB_SIZE    equ     128
     2000             (        forth.asm):00038         DICT_START  equ     $2000       ; user dictionary grows from here
                      (        forth.asm):00039         
     0080             (        forth.asm):00040         F_IMMED     equ     $80         ; flags: immediate
     0040             (        forth.asm):00041         F_HIDDEN    equ     $40         ; flags: hidden (smudge)
     001F             (        forth.asm):00042         F_LENMASK   equ     $1F         ; low 5 bits = name length (max 31)
                      (        forth.asm):00043         
                      (        forth.asm):00044         ; Forth VM entry vector — used by INTERPRET to pass control to a word.
                      (        forth.asm):00045         ; EXECUTE primitive expects TOS = CFA.
                      (        forth.asm):00046         
                      (        forth.asm):00047         ; --- cold-start vector -----------------------------------------------------
                      (        forth.asm):00048                     org     $0100
0100                  (        forth.asm):00049         cold:
0100 10CEFEFE         (        forth.asm):00050                     lds     #RSP_TOP            ; return stack
0104 CEBFFE           (        forth.asm):00051                     ldu     #PSP_TOP            ; data stack
                      (        forth.asm):00052                     ; ACIA init: master reset then 8N1 / div-16 / no IRQ.
0107 8603             (        forth.asm):00053                     lda     #$03
0109 B7FF00           (        forth.asm):00054                     sta     ACIA_SR
010C 8615             (        forth.asm):00055                     lda     #$15
010E B7FF00           (        forth.asm):00056                     sta     ACIA_SR
                      (        forth.asm):00057         
                      (        forth.asm):00058                     ; Greeting so the user knows the REPL is alive.
0111 8E0130           (        forth.asm):00059                     ldx     #msg_ready
0114 8D5C             (        forth.asm):00060                     bsr     puts_native
                      (        forth.asm):00061                     ; Seed HERE / LATEST / STATE.
0116 8E2000           (        forth.asm):00062                     ldx     #DICT_START
0119 BF04C5           (        forth.asm):00063                     stx     var_HERE
011C 8E0BC3           (        forth.asm):00064                     ldx     #last_builtin_link
011F BF04C3           (        forth.asm):00065                     stx     var_LATEST
0122 8E0000           (        forth.asm):00066                     ldx     #0
0125 BF04B6           (        forth.asm):00067                     stx     var_STATE
                      (        forth.asm):00068                     ; Enter the Forth VM: IP → boot_code → cfa_QUIT → DOCOL → QUIT body.
0128 8E012E           (        forth.asm):00069                     ldx     #boot_code
012B 7E0183           (        forth.asm):00070                     jmp     NEXT
                      (        forth.asm):00071         
012E 0BCA             (        forth.asm):00072         boot_code:  fdb     cfa_QUIT
                      (        forth.asm):00073         
0130 48686120466F7274 (        forth.asm):00074         msg_ready   fcc     "Hha Forth for MC6809 ready."
     6820666F72204D43
     3638303920726561
     64792E
014B 0D0A             (        forth.asm):00075                     fcb     $0D,$0A
014D 2863292032303236 (        forth.asm):00076                     fcc     "(c) 2026 hha0x617 - MIT/Apache-2.0"
     2068686130783631
     37202D204D49542F
     4170616368652D32
     2E30
016F 0D0A00           (        forth.asm):00077                     fcb     $0D,$0A,0
                      (        forth.asm):00078         
                      (        forth.asm):00079         ; Native puts: X -> NUL-terminated string. Uses A, B; preserves X? no,
                      (        forth.asm):00080         ; destroys X. Used during cold boot only.
0172                  (        forth.asm):00081         puts_native:
0172 A680             (        forth.asm):00082                     lda     ,x+
0174 270C             (        forth.asm):00083                     beq     puts_done
0176 F6FF00           (        forth.asm):00084         puts_wait:  ldb     ACIA_SR
0179 C502             (        forth.asm):00085                     bitb    #$02
017B 27F9             (        forth.asm):00086                     beq     puts_wait
017D B7FF01           (        forth.asm):00087                     sta     ACIA_DATA
0180 20F0             (        forth.asm):00088                     bra     puts_native
0182                  (        forth.asm):00089         puts_done:
0182 39               (        forth.asm):00090                     rts
                      (        forth.asm):00091         
                      (        forth.asm):00092         ; ---------------------------------------------------------------------------
                      (        forth.asm):00093         ; Inner interpreter — NEXT / DOCOL / EXIT
                      (        forth.asm):00094         ; ---------------------------------------------------------------------------
0183                  (        forth.asm):00095         NEXT:
0183 10AE81           (        forth.asm):00096                     ldy     ,x++            ; W = *IP; IP += 2
0186 6EB4             (        forth.asm):00097                     jmp     [,y]            ; jump through CFA → code field's code
                      (        forth.asm):00098         
                      (        forth.asm):00099         ; DOCOL: enter a colon definition. Called via NEXT when the CFA's contents
                      (        forth.asm):00100         ; point here. On entry Y = CFA; the body starts at Y+2.
0188                  (        forth.asm):00101         DOCOL:
0188 3410             (        forth.asm):00102                     pshs    x               ; push old IP onto return stack
018A 3022             (        forth.asm):00103                     leax    2,y             ; IP = CFA + 2 (body address)
018C 7E0183           (        forth.asm):00104                     jmp     NEXT
                      (        forth.asm):00105         
                      (        forth.asm):00106         ; DOVAR: code field for VARIABLE. Pushes PFA onto the data stack.
018F                  (        forth.asm):00107         DOVAR:
018F 3122             (        forth.asm):00108                     leay    2,y             ; PFA = CFA + 2
0191 10AFC3           (        forth.asm):00109                     sty     ,--u            ; push PFA as 16-bit cell
0194 7E0183           (        forth.asm):00110                     jmp     NEXT
                      (        forth.asm):00111         
                      (        forth.asm):00112         ; DOCON: code field for CONSTANT. Pushes *PFA onto the data stack.
0197                  (        forth.asm):00113         DOCON:
0197 EC22             (        forth.asm):00114                     ldd     2,y             ; D = value stored at PFA
0199 EDC3             (        forth.asm):00115                     std     ,--u
019B 7E0183           (        forth.asm):00116                     jmp     NEXT
                      (        forth.asm):00117         
                      (        forth.asm):00118         ; ---------------------------------------------------------------------------
                      (        forth.asm):00119         ; Built-in dictionary — linked list grows from `last_builtin_link`, each
                      (        forth.asm):00120         ; entry has:
                      (        forth.asm):00121         ;
                      (        forth.asm):00122         ;     +0  flags+length byte
                      (        forth.asm):00123         ;     +1  name bytes (len bytes)
                      (        forth.asm):00124         ;     +N  link field (2 bytes, big-endian — pointer to previous entry's
                      (        forth.asm):00125         ;         flags byte, i.e. NFA of previous word)
                      (        forth.asm):00126         ;     +N+2  CFA  (2 bytes — for primitives: address of code;
                      (        forth.asm):00127         ;                        for colon defs: address of DOCOL)
                      (        forth.asm):00128         ;     +N+4  PFA  (body — only for non-primitives)
                      (        forth.asm):00129         ;
                      (        forth.asm):00130         ; The `WORD` macro below lays out a primitive header. A secondary macro lays
                      (        forth.asm):00131         ; out a colon definition header.
                      (        forth.asm):00132         ; ---------------------------------------------------------------------------
                      (        forth.asm):00133         
                      (        forth.asm):00134         ; Each primitive's header starts with a label for the flags/length byte
                      (        forth.asm):00135         ; (the NFA), followed by name+link+CFA. We emit them with inline .fcb/.fdb.
                      (        forth.asm):00136         
                      (        forth.asm):00137         ; link anchor: NULL terminator at the bottom of the chain
     0000             (        forth.asm):00138         prev_link   set     0
                      (        forth.asm):00139         
                      (        forth.asm):00140                     ; -- primitive: EXIT ( -- )  restore IP from R stack ------------
019E 04               (        forth.asm):00141         nfa_EXIT    fcb     4
019F 45584954         (        forth.asm):00142                     fcc     "EXIT"
01A3 0000             (        forth.asm):00143         lnk_EXIT    fdb     prev_link
01A5 01A7             (        forth.asm):00144         cfa_EXIT    fdb     code_EXIT
     019E             (        forth.asm):00145         prev_link   set     nfa_EXIT
                      (        forth.asm):00146         
01A7 3510             (        forth.asm):00147         code_EXIT:  puls    x               ; IP = saved IP
01A9 7E0183           (        forth.asm):00148                     jmp     NEXT
                      (        forth.asm):00149         
                      (        forth.asm):00150                     ; -- primitive: (LIT) — inline literal --------------------------
01AC 05               (        forth.asm):00151         nfa_LIT     fcb     5
01AD 284C495429       (        forth.asm):00152                     fcc     "(LIT)"
01B2 019E             (        forth.asm):00153         lnk_LIT     fdb     prev_link
01B4 01B6             (        forth.asm):00154         cfa_LIT     fdb     code_LIT
     01AC             (        forth.asm):00155         prev_link   set     nfa_LIT
                      (        forth.asm):00156         
01B6 EC81             (        forth.asm):00157         code_LIT:   ldd     ,x++            ; D = *IP++; IP advanced past the cell
01B8 EDC3             (        forth.asm):00158                     std     ,--u
01BA 7E0183           (        forth.asm):00159                     jmp     NEXT
                      (        forth.asm):00160         
                      (        forth.asm):00161                     ; -- primitive: (0BRANCH) — branch if TOS == 0 ------------------
01BD 09               (        forth.asm):00162         nfa_0BR     fcb     9
01BE 28304252414E4348 (        forth.asm):00163                     fcc     "(0BRANCH)"
     29
01C7 01AC             (        forth.asm):00164         lnk_0BR     fdb     prev_link
01C9 01CB             (        forth.asm):00165         cfa_0BR     fdb     code_0BR
     01BD             (        forth.asm):00166         prev_link   set     nfa_0BR
                      (        forth.asm):00167         
01CB ECC1             (        forth.asm):00168         code_0BR:   ldd     ,u++            ; pop condition
01CD 10830000         (        forth.asm):00169                     cmpd    #0
01D1 2705             (        forth.asm):00170                     beq     take_0br
01D3 3002             (        forth.asm):00171                     leax    2,x             ; skip offset, don't branch
01D5 7E0183           (        forth.asm):00172                     jmp     NEXT
01D8 EC84             (        forth.asm):00173         take_0br:   ldd     ,x              ; D = branch offset (signed, cell-relative)
01DA 308B             (        forth.asm):00174                     leax    d,x             ; IP += offset
01DC 7E0183           (        forth.asm):00175                     jmp     NEXT
                      (        forth.asm):00176         
                      (        forth.asm):00177                     ; -- primitive: (BRANCH) — unconditional branch -----------------
01DF 08               (        forth.asm):00178         nfa_BR      fcb     8
01E0 284252414E434829 (        forth.asm):00179                     fcc     "(BRANCH)"
01E8 01BD             (        forth.asm):00180         lnk_BR      fdb     prev_link
01EA 01EC             (        forth.asm):00181         cfa_BR      fdb     code_BR
     01DF             (        forth.asm):00182         prev_link   set     nfa_BR
                      (        forth.asm):00183         
01EC EC84             (        forth.asm):00184         code_BR:    ldd     ,x
01EE 308B             (        forth.asm):00185                     leax    d,x
01F0 7E0183           (        forth.asm):00186                     jmp     NEXT
                      (        forth.asm):00187         
                      (        forth.asm):00188                     ; -- primitive: EXECUTE ( xt -- ) -------------------------------
01F3 07               (        forth.asm):00189         nfa_EXEC    fcb     7
01F4 45584543555445   (        forth.asm):00190                     fcc     "EXECUTE"
01FB 01DF             (        forth.asm):00191         lnk_EXEC    fdb     prev_link
01FD 01FF             (        forth.asm):00192         cfa_EXEC    fdb     code_EXEC
     01F3             (        forth.asm):00193         prev_link   set     nfa_EXEC
                      (        forth.asm):00194         
01FF 10AEC1           (        forth.asm):00195         code_EXEC:  ldy     ,u++            ; Y = CFA popped from data stack
0202 6EB4             (        forth.asm):00196                     jmp     [,y]
                      (        forth.asm):00197         
                      (        forth.asm):00198         ; ---------------------------------------------------------------------------
                      (        forth.asm):00199         ; Stack primitives
                      (        forth.asm):00200         ; ---------------------------------------------------------------------------
                      (        forth.asm):00201                     ; DUP ( a -- a a )
0204 03               (        forth.asm):00202         nfa_DUP     fcb     3
0205 445550           (        forth.asm):00203                     fcc     "DUP"
0208 01F3             (        forth.asm):00204         lnk_DUP     fdb     prev_link
020A 020C             (        forth.asm):00205         cfa_DUP     fdb     code_DUP
     0204             (        forth.asm):00206         prev_link   set     nfa_DUP
020C ECC4             (        forth.asm):00207         code_DUP:   ldd     ,u
020E EDC3             (        forth.asm):00208                     std     ,--u
0210 7E0183           (        forth.asm):00209                     jmp     NEXT
                      (        forth.asm):00210         
                      (        forth.asm):00211                     ; DROP ( a -- )
0213 04               (        forth.asm):00212         nfa_DROP    fcb     4
0214 44524F50         (        forth.asm):00213                     fcc     "DROP"
0218 0204             (        forth.asm):00214         lnk_DROP    fdb     prev_link
021A 021C             (        forth.asm):00215         cfa_DROP    fdb     code_DROP
     0213             (        forth.asm):00216         prev_link   set     nfa_DROP
021C 3342             (        forth.asm):00217         code_DROP:  leau    2,u
021E 7E0183           (        forth.asm):00218                     jmp     NEXT
                      (        forth.asm):00219         
                      (        forth.asm):00220                     ; SWAP ( a b -- b a )
0221 04               (        forth.asm):00221         nfa_SWAP    fcb     4
0222 53574150         (        forth.asm):00222                     fcc     "SWAP"
0226 0213             (        forth.asm):00223         lnk_SWAP    fdb     prev_link
0228 022A             (        forth.asm):00224         cfa_SWAP    fdb     code_SWAP
     0221             (        forth.asm):00225         prev_link   set     nfa_SWAP
022A ECC4             (        forth.asm):00226         code_SWAP:  ldd     ,u
022C 10AE42           (        forth.asm):00227                     ldy     2,u
022F 10AFC4           (        forth.asm):00228                     sty     ,u
0232 ED42             (        forth.asm):00229                     std     2,u
0234 7E0183           (        forth.asm):00230                     jmp     NEXT
                      (        forth.asm):00231         
                      (        forth.asm):00232                     ; OVER ( a b -- a b a )
0237 04               (        forth.asm):00233         nfa_OVER    fcb     4
0238 4F564552         (        forth.asm):00234                     fcc     "OVER"
023C 0221             (        forth.asm):00235         lnk_OVER    fdb     prev_link
023E 0240             (        forth.asm):00236         cfa_OVER    fdb     code_OVER
     0237             (        forth.asm):00237         prev_link   set     nfa_OVER
0240 EC42             (        forth.asm):00238         code_OVER:  ldd     2,u
0242 EDC3             (        forth.asm):00239                     std     ,--u
0244 7E0183           (        forth.asm):00240                     jmp     NEXT
                      (        forth.asm):00241         
                      (        forth.asm):00242                     ; ROT ( a b c -- b c a )
0247 03               (        forth.asm):00243         nfa_ROT     fcb     3
0248 524F54           (        forth.asm):00244                     fcc     "ROT"
024B 0237             (        forth.asm):00245         lnk_ROT     fdb     prev_link
024D 024F             (        forth.asm):00246         cfa_ROT     fdb     code_ROT
     0247             (        forth.asm):00247         prev_link   set     nfa_ROT
024F EC44             (        forth.asm):00248         code_ROT:   ldd     4,u             ; a
0251 10AE42           (        forth.asm):00249                     ldy     2,u             ; b
0254 10AF44           (        forth.asm):00250                     sty     4,u
0257 10AEC4           (        forth.asm):00251                     ldy     ,u              ; c
025A 10AF42           (        forth.asm):00252                     sty     2,u
025D EDC4             (        forth.asm):00253                     std     ,u
025F 7E0183           (        forth.asm):00254                     jmp     NEXT
                      (        forth.asm):00255         
                      (        forth.asm):00256                     ; >R ( n -- ) ( R: -- n )
0262 02               (        forth.asm):00257         nfa_TOR     fcb     2
0263 3E52             (        forth.asm):00258                     fcc     ">R"
0265 0247             (        forth.asm):00259         lnk_TOR     fdb     prev_link
0267 0269             (        forth.asm):00260         cfa_TOR     fdb     code_TOR
     0262             (        forth.asm):00261         prev_link   set     nfa_TOR
0269 ECC1             (        forth.asm):00262         code_TOR:   ldd     ,u++
026B 3406             (        forth.asm):00263                     pshs    d
026D 7E0183           (        forth.asm):00264                     jmp     NEXT
                      (        forth.asm):00265         
                      (        forth.asm):00266                     ; R> ( -- n ) ( R: n -- )
0270 02               (        forth.asm):00267         nfa_RFROM   fcb     2
0271 523E             (        forth.asm):00268                     fcc     "R>"
0273 0262             (        forth.asm):00269         lnk_RFROM   fdb     prev_link
0275 0277             (        forth.asm):00270         cfa_RFROM   fdb     code_RFROM
     0270             (        forth.asm):00271         prev_link   set     nfa_RFROM
0277 3506             (        forth.asm):00272         code_RFROM: puls    d
0279 EDC3             (        forth.asm):00273                     std     ,--u
027B 7E0183           (        forth.asm):00274                     jmp     NEXT
                      (        forth.asm):00275         
                      (        forth.asm):00276                     ; R@ ( -- n ) ( R: n -- n )
027E 02               (        forth.asm):00277         nfa_RFETCH  fcb     2
027F 5240             (        forth.asm):00278                     fcc     "R@"
0281 0270             (        forth.asm):00279         lnk_RFETCH  fdb     prev_link
0283 0285             (        forth.asm):00280         cfa_RFETCH  fdb     code_RFETCH
     027E             (        forth.asm):00281         prev_link   set     nfa_RFETCH
0285                  (        forth.asm):00282         code_RFETCH:
0285 ECE4             (        forth.asm):00283                     ldd     ,s
0287 EDC3             (        forth.asm):00284                     std     ,--u
0289 7E0183           (        forth.asm):00285                     jmp     NEXT
                      (        forth.asm):00286         
                      (        forth.asm):00287         ; ---------------------------------------------------------------------------
                      (        forth.asm):00288         ; Arithmetic / logical primitives — 16-bit signed
                      (        forth.asm):00289         ; ---------------------------------------------------------------------------
                      (        forth.asm):00290                     ; + ( a b -- a+b )
028C 01               (        forth.asm):00291         nfa_ADD     fcb     1
028D 2B               (        forth.asm):00292                     fcc     "+"
028E 027E             (        forth.asm):00293         lnk_ADD     fdb     prev_link
0290 0292             (        forth.asm):00294         cfa_ADD     fdb     code_ADD
     028C             (        forth.asm):00295         prev_link   set     nfa_ADD
0292 ECC1             (        forth.asm):00296         code_ADD:   ldd     ,u++
0294 E3C4             (        forth.asm):00297                     addd    ,u
0296 EDC4             (        forth.asm):00298                     std     ,u
0298 7E0183           (        forth.asm):00299                     jmp     NEXT
                      (        forth.asm):00300         
                      (        forth.asm):00301                     ; - ( a b -- a-b )
029B 01               (        forth.asm):00302         nfa_SUB     fcb     1
029C 2D               (        forth.asm):00303                     fcc     "-"
029D 028C             (        forth.asm):00304         lnk_SUB     fdb     prev_link
029F 02A1             (        forth.asm):00305         cfa_SUB     fdb     code_SUB
     029B             (        forth.asm):00306         prev_link   set     nfa_SUB
02A1 EC42             (        forth.asm):00307         code_SUB:   ldd     2,u             ; D = a
02A3 A3C4             (        forth.asm):00308                     subd    ,u              ; D = a - b
02A5 3342             (        forth.asm):00309                     leau    2,u
02A7 EDC4             (        forth.asm):00310                     std     ,u
02A9 7E0183           (        forth.asm):00311                     jmp     NEXT
                      (        forth.asm):00312         
                      (        forth.asm):00313                     ; * ( a b -- a*b )  16-bit multiply, low-16 result (sign-agnostic)
                      (        forth.asm):00314                     ; a = (ah:al) at 2,u, b = (bh:bl) at 0,u
                      (        forth.asm):00315                     ;   a*b = ah*bh*65536 + (ah*bl + al*bh)*256 + al*bl
                      (        forth.asm):00316                     ; For the low 16 bits we discard ah*bh, then add in the low bytes
                      (        forth.asm):00317                     ; of (ah*bl) and (al*bh) shifted up 8. Three MULs total.
02AC 01               (        forth.asm):00318         nfa_MUL     fcb     1
02AD 2A               (        forth.asm):00319                     fcc     "*"
02AE 029B             (        forth.asm):00320         lnk_MUL     fdb     prev_link
02B0 02B2             (        forth.asm):00321         cfa_MUL     fdb     code_MUL
     02AC             (        forth.asm):00322         prev_link   set     nfa_MUL
02B2 A643             (        forth.asm):00323         code_MUL:   lda     3,u             ; A = al
02B4 E641             (        forth.asm):00324                     ldb     1,u             ; B = bl
02B6 3D               (        forth.asm):00325                     mul                     ; D = al*bl
02B7 3406             (        forth.asm):00326                     pshs    d               ; save partial: ,s=hi 1,s=lo
02B9 A642             (        forth.asm):00327                     lda     2,u             ; A = ah
02BB E641             (        forth.asm):00328                     ldb     1,u             ; B = bl
02BD 3D               (        forth.asm):00329                     mul                     ; D = ah*bl (we only want B, the low 8 bits)
02BE EBE4             (        forth.asm):00330                     addb    ,s              ; add into hi byte of partial
02C0 E7E4             (        forth.asm):00331                     stb     ,s
02C2 A643             (        forth.asm):00332                     lda     3,u             ; A = al
02C4 E6C4             (        forth.asm):00333                     ldb     ,u              ; B = bh
