                      (        forth.asm):00003         ;
                      (        forth.asm):00004         ; ---------------------------------------------------------------------------
                      (        forth.asm):00005         ; Tiny Forth for MC6809 — ITC (indirect-threaded) kernel running on the
                      (        forth.asm):00006         ; emfe_plugin_mc6809 environment (MC6850 ACIA at $FF00/$FF01, 64 KB RAM).
                      (        forth.asm):00007         ;
                      (        forth.asm):00008         ; Register conventions:
                      (        forth.asm):00009         ;   U = data stack pointer (grows downward; TOS at  0,U)
                      (        forth.asm):00010         ;   S = return stack pointer (grows downward; also holds BSR/JSR frames)
                      (        forth.asm):00011         ;   X = IP                  (points at next CFA word to execute)
                      (        forth.asm):00012         ;   Y = W                   (holds CFA during NEXT / DOCOL)
                      (        forth.asm):00013         ;   D = scratch / arithmetic accumulator
                      (        forth.asm):00014         ;
                      (        forth.asm):00015         ; Threading (ITC):
                      (        forth.asm):00016         ;   CFA cell  = pointer to native code (for primitives) or DOCOL (for colon
                      (        forth.asm):00017         ;               definitions).
                      (        forth.asm):00018         ;   NEXT does: Y = *IP++; JMP [,Y]   (indirect through Y)
                      (        forth.asm):00019         ;
                      (        forth.asm):00020         ; Memory map:
                      (        forth.asm):00021         ;   $0100..$1FFF   kernel code + built-in dictionary
                      (        forth.asm):00022         ;   $2000..$9FFF   user dictionary (HERE grows upward)
                      (        forth.asm):00023         ;   $A000..$A07F   TIB (terminal input buffer, 128 bytes)
                      (        forth.asm):00024         ;   $B000..$BFFE   data stack (U starts at $BFFE)
                      (        forth.asm):00025         ;   $C000..$FEFE   return stack (S starts at $FEFE)
                      (        forth.asm):00026         ;   $FF00/$FF01    ACIA SR/CR, RDR/TDR
                      (        forth.asm):00027         ;   $FFFE/$FFFF    reset vector → cold
                      (        forth.asm):00028         ; ---------------------------------------------------------------------------
                      (        forth.asm):00029         
                      (        forth.asm):00030         ; --- equates ---------------------------------------------------------------
     FF00             (        forth.asm):00031         ACIA_SR     equ     $FF00       ; read: status      write: control
     FF01             (        forth.asm):00032         ACIA_DATA   equ     $FF01       ; read: RDR         write: TDR
                      (        forth.asm):00033         
     BFFE             (        forth.asm):00034         PSP_TOP     equ     $BFFE       ; data stack top (U)
     FEFE             (        forth.asm):00035         RSP_TOP     equ     $FEFE       ; return stack top (S)
     A000             (        forth.asm):00036         TIB_ADDR    equ     $A000       ; terminal input buffer
     0080             (        forth.asm):00037         TIB_SIZE    equ     128
     2000             (        forth.asm):00038         DICT_START  equ     $2000       ; user dictionary grows from here
                      (        forth.asm):00039         
     0080             (        forth.asm):00040         F_IMMED     equ     $80         ; flags: immediate
     0040             (        forth.asm):00041         F_HIDDEN    equ     $40         ; flags: hidden (smudge)
     001F             (        forth.asm):00042         F_LENMASK   equ     $1F         ; low 5 bits = name length (max 31)
                      (        forth.asm):00043         
                      (        forth.asm):00044         ; Forth VM entry vector — used by INTERPRET to pass control to a word.
                      (        forth.asm):00045         ; EXECUTE primitive expects TOS = CFA.
                      (        forth.asm):00046         
                      (        forth.asm):00047         ; --- cold-start vector -----------------------------------------------------
                      (        forth.asm):00048                     org     $0100
0100                  (        forth.asm):00049         cold:
0100 10CEFEFE         (        forth.asm):00050                     lds     #RSP_TOP            ; return stack
0104 CEBFFE           (        forth.asm):00051                     ldu     #PSP_TOP            ; data stack
                      (        forth.asm):00052                     ; ACIA init: master reset then 8N1 / div-16 / no IRQ.
0107 8603             (        forth.asm):00053                     lda     #$03
0109 B7FF00           (        forth.asm):00054                     sta     ACIA_SR
010C 8615             (        forth.asm):00055                     lda     #$15
010E B7FF00           (        forth.asm):00056                     sta     ACIA_SR
                      (        forth.asm):00057         
                      (        forth.asm):00058                     ; Greeting so the user knows the REPL is alive.
0111 8E0130           (        forth.asm):00059                     ldx     #msg_ready
0114 8D5D             (        forth.asm):00060                     bsr     puts_native
                      (        forth.asm):00061                     ; Seed HERE / LATEST / STATE.
0116 8E2000           (        forth.asm):00062                     ldx     #DICT_START
0119 BF0469           (        forth.asm):00063                     stx     var_HERE
011C 8E0AF3           (        forth.asm):00064                     ldx     #last_builtin_link
011F BF0467           (        forth.asm):00065                     stx     var_LATEST
0122 8E0000           (        forth.asm):00066                     ldx     #0
0125 BF045A           (        forth.asm):00067                     stx     var_STATE
                      (        forth.asm):00068                     ; Enter the Forth VM: IP → boot_code → cfa_QUIT → DOCOL → QUIT body.
0128 8E012E           (        forth.asm):00069                     ldx     #boot_code
012B 7E0184           (        forth.asm):00070                     jmp     NEXT
                      (        forth.asm):00071         
012E 0AFA             (        forth.asm):00072         boot_code:  fdb     cfa_QUIT
                      (        forth.asm):00073         
0130 54696E7920466F72 (        forth.asm):00074         msg_ready   fcc     "Tiny Forth for MC6809 ready."
     746820666F72204D
     4336383039207265
     6164792E
014C 0D0A             (        forth.asm):00075                     fcb     $0D,$0A
014E 2863292032303236 (        forth.asm):00076                     fcc     "(c) 2026 hha0x617 - MIT/Apache-2.0"
     2068686130783631
     37202D204D49542F
     4170616368652D32
     2E30
0170 0D0A00           (        forth.asm):00077                     fcb     $0D,$0A,0
                      (        forth.asm):00078         
                      (        forth.asm):00079         ; Native puts: X -> NUL-terminated string. Uses A, B; preserves X? no,
                      (        forth.asm):00080         ; destroys X. Used during cold boot only.
0173                  (        forth.asm):00081         puts_native:
0173 A680             (        forth.asm):00082                     lda     ,x+
0175 270C             (        forth.asm):00083                     beq     puts_done
0177 F6FF00           (        forth.asm):00084         puts_wait:  ldb     ACIA_SR
017A C502             (        forth.asm):00085                     bitb    #$02
017C 27F9             (        forth.asm):00086                     beq     puts_wait
017E B7FF01           (        forth.asm):00087                     sta     ACIA_DATA
0181 20F0             (        forth.asm):00088                     bra     puts_native
0183                  (        forth.asm):00089         puts_done:
0183 39               (        forth.asm):00090                     rts
                      (        forth.asm):00091         
                      (        forth.asm):00092         ; ---------------------------------------------------------------------------
                      (        forth.asm):00093         ; Inner interpreter — NEXT / DOCOL / EXIT
                      (        forth.asm):00094         ; ---------------------------------------------------------------------------
0184                  (        forth.asm):00095         NEXT:
0184 10AE81           (        forth.asm):00096                     ldy     ,x++            ; W = *IP; IP += 2
0187 6EB4             (        forth.asm):00097                     jmp     [,y]            ; jump through CFA → code field's code
                      (        forth.asm):00098         
                      (        forth.asm):00099         ; DOCOL: enter a colon definition. Called via NEXT when the CFA's contents
                      (        forth.asm):00100         ; point here. On entry Y = CFA; the body starts at Y+2.
0189                  (        forth.asm):00101         DOCOL:
0189 3410             (        forth.asm):00102                     pshs    x               ; push old IP onto return stack
018B 3022             (        forth.asm):00103                     leax    2,y             ; IP = CFA + 2 (body address)
018D 7E0184           (        forth.asm):00104                     jmp     NEXT
                      (        forth.asm):00105         
                      (        forth.asm):00106         ; DOVAR: code field for VARIABLE. Pushes PFA onto the data stack.
0190                  (        forth.asm):00107         DOVAR:
0190 3122             (        forth.asm):00108                     leay    2,y             ; PFA = CFA + 2
0192 10AFC3           (        forth.asm):00109                     sty     ,--u            ; push PFA as 16-bit cell
0195 7E0184           (        forth.asm):00110                     jmp     NEXT
                      (        forth.asm):00111         
                      (        forth.asm):00112         ; DOCON: code field for CONSTANT. Pushes *PFA onto the data stack.
0198                  (        forth.asm):00113         DOCON:
0198 EC22             (        forth.asm):00114                     ldd     2,y             ; D = value stored at PFA
019A EDC3             (        forth.asm):00115                     std     ,--u
019C 7E0184           (        forth.asm):00116                     jmp     NEXT
                      (        forth.asm):00117         
                      (        forth.asm):00118         ; ---------------------------------------------------------------------------
                      (        forth.asm):00119         ; Built-in dictionary — linked list grows from `last_builtin_link`, each
                      (        forth.asm):00120         ; entry has:
                      (        forth.asm):00121         ;
                      (        forth.asm):00122         ;     +0  flags+length byte
                      (        forth.asm):00123         ;     +1  name bytes (len bytes)
                      (        forth.asm):00124         ;     +N  link field (2 bytes, big-endian — pointer to previous entry's
                      (        forth.asm):00125         ;         flags byte, i.e. NFA of previous word)
                      (        forth.asm):00126         ;     +N+2  CFA  (2 bytes — for primitives: address of code;
                      (        forth.asm):00127         ;                        for colon defs: address of DOCOL)
                      (        forth.asm):00128         ;     +N+4  PFA  (body — only for non-primitives)
                      (        forth.asm):00129         ;
                      (        forth.asm):00130         ; The `WORD` macro below lays out a primitive header. A secondary macro lays
                      (        forth.asm):00131         ; out a colon definition header.
                      (        forth.asm):00132         ; ---------------------------------------------------------------------------
                      (        forth.asm):00133         
                      (        forth.asm):00134         ; Each primitive's header starts with a label for the flags/length byte
                      (        forth.asm):00135         ; (the NFA), followed by name+link+CFA. We emit them with inline .fcb/.fdb.
                      (        forth.asm):00136         
                      (        forth.asm):00137         ; link anchor: NULL terminator at the bottom of the chain
     0000             (        forth.asm):00138         prev_link   set     0
                      (        forth.asm):00139         
                      (        forth.asm):00140                     ; -- primitive: EXIT ( -- )  restore IP from R stack ------------
019F 04               (        forth.asm):00141         nfa_EXIT    fcb     4
01A0 45584954         (        forth.asm):00142                     fcc     "EXIT"
01A4 0000             (        forth.asm):00143         lnk_EXIT    fdb     prev_link
01A6 01A8             (        forth.asm):00144         cfa_EXIT    fdb     code_EXIT
     019F             (        forth.asm):00145         prev_link   set     nfa_EXIT
                      (        forth.asm):00146         
01A8 3510             (        forth.asm):00147         code_EXIT:  puls    x               ; IP = saved IP
01AA 7E0184           (        forth.asm):00148                     jmp     NEXT
                      (        forth.asm):00149         
                      (        forth.asm):00150                     ; -- primitive: (LIT) — inline literal --------------------------
01AD 05               (        forth.asm):00151         nfa_LIT     fcb     5
01AE 284C495429       (        forth.asm):00152                     fcc     "(LIT)"
01B3 019F             (        forth.asm):00153         lnk_LIT     fdb     prev_link
01B5 01B7             (        forth.asm):00154         cfa_LIT     fdb     code_LIT
     01AD             (        forth.asm):00155         prev_link   set     nfa_LIT
                      (        forth.asm):00156         
01B7 EC81             (        forth.asm):00157         code_LIT:   ldd     ,x++            ; D = *IP++; IP advanced past the cell
01B9 EDC3             (        forth.asm):00158                     std     ,--u
01BB 7E0184           (        forth.asm):00159                     jmp     NEXT
                      (        forth.asm):00160         
                      (        forth.asm):00161                     ; -- primitive: (0BRANCH) — branch if TOS == 0 ------------------
01BE 09               (        forth.asm):00162         nfa_0BR     fcb     9
01BF 28304252414E4348 (        forth.asm):00163                     fcc     "(0BRANCH)"
     29
01C8 01AD             (        forth.asm):00164         lnk_0BR     fdb     prev_link
01CA 01CC             (        forth.asm):00165         cfa_0BR     fdb     code_0BR
     01BE             (        forth.asm):00166         prev_link   set     nfa_0BR
                      (        forth.asm):00167         
01CC ECC1             (        forth.asm):00168         code_0BR:   ldd     ,u++            ; pop condition
01CE 10830000         (        forth.asm):00169                     cmpd    #0
01D2 2705             (        forth.asm):00170                     beq     take_0br
01D4 3002             (        forth.asm):00171                     leax    2,x             ; skip offset, don't branch
01D6 7E0184           (        forth.asm):00172                     jmp     NEXT
01D9 EC84             (        forth.asm):00173         take_0br:   ldd     ,x              ; D = branch offset (signed, cell-relative)
01DB 308B             (        forth.asm):00174                     leax    d,x             ; IP += offset
01DD 7E0184           (        forth.asm):00175                     jmp     NEXT
                      (        forth.asm):00176         
                      (        forth.asm):00177                     ; -- primitive: (BRANCH) — unconditional branch -----------------
01E0 08               (        forth.asm):00178         nfa_BR      fcb     8
01E1 284252414E434829 (        forth.asm):00179                     fcc     "(BRANCH)"
01E9 01BE             (        forth.asm):00180         lnk_BR      fdb     prev_link
01EB 01ED             (        forth.asm):00181         cfa_BR      fdb     code_BR
     01E0             (        forth.asm):00182         prev_link   set     nfa_BR
                      (        forth.asm):00183         
01ED EC84             (        forth.asm):00184         code_BR:    ldd     ,x
01EF 308B             (        forth.asm):00185                     leax    d,x
01F1 7E0184           (        forth.asm):00186                     jmp     NEXT
                      (        forth.asm):00187         
                      (        forth.asm):00188                     ; -- primitive: EXECUTE ( xt -- ) -------------------------------
01F4 07               (        forth.asm):00189         nfa_EXEC    fcb     7
01F5 45584543555445   (        forth.asm):00190                     fcc     "EXECUTE"
01FC 01E0             (        forth.asm):00191         lnk_EXEC    fdb     prev_link
01FE 0200             (        forth.asm):00192         cfa_EXEC    fdb     code_EXEC
     01F4             (        forth.asm):00193         prev_link   set     nfa_EXEC
                      (        forth.asm):00194         
0200 10AEC1           (        forth.asm):00195         code_EXEC:  ldy     ,u++            ; Y = CFA popped from data stack
0203 6EB4             (        forth.asm):00196                     jmp     [,y]
                      (        forth.asm):00197         
                      (        forth.asm):00198         ; ---------------------------------------------------------------------------
                      (        forth.asm):00199         ; Stack primitives
                      (        forth.asm):00200         ; ---------------------------------------------------------------------------
                      (        forth.asm):00201                     ; DUP ( a -- a a )
0205 03               (        forth.asm):00202         nfa_DUP     fcb     3
0206 445550           (        forth.asm):00203                     fcc     "DUP"
0209 01F4             (        forth.asm):00204         lnk_DUP     fdb     prev_link
020B 020D             (        forth.asm):00205         cfa_DUP     fdb     code_DUP
     0205             (        forth.asm):00206         prev_link   set     nfa_DUP
020D ECC4             (        forth.asm):00207         code_DUP:   ldd     ,u
020F EDC3             (        forth.asm):00208                     std     ,--u
0211 7E0184           (        forth.asm):00209                     jmp     NEXT
                      (        forth.asm):00210         
                      (        forth.asm):00211                     ; DROP ( a -- )
0214 04               (        forth.asm):00212         nfa_DROP    fcb     4
0215 44524F50         (        forth.asm):00213                     fcc     "DROP"
0219 0205             (        forth.asm):00214         lnk_DROP    fdb     prev_link
021B 021D             (        forth.asm):00215         cfa_DROP    fdb     code_DROP
     0214             (        forth.asm):00216         prev_link   set     nfa_DROP
021D 3342             (        forth.asm):00217         code_DROP:  leau    2,u
021F 7E0184           (        forth.asm):00218                     jmp     NEXT
                      (        forth.asm):00219         
                      (        forth.asm):00220                     ; SWAP ( a b -- b a )
0222 04               (        forth.asm):00221         nfa_SWAP    fcb     4
0223 53574150         (        forth.asm):00222                     fcc     "SWAP"
0227 0214             (        forth.asm):00223         lnk_SWAP    fdb     prev_link
0229 022B             (        forth.asm):00224         cfa_SWAP    fdb     code_SWAP
     0222             (        forth.asm):00225         prev_link   set     nfa_SWAP
022B ECC4             (        forth.asm):00226         code_SWAP:  ldd     ,u
022D 10AE42           (        forth.asm):00227                     ldy     2,u
0230 10AFC4           (        forth.asm):00228                     sty     ,u
0233 ED42             (        forth.asm):00229                     std     2,u
0235 7E0184           (        forth.asm):00230                     jmp     NEXT
                      (        forth.asm):00231         
                      (        forth.asm):00232                     ; OVER ( a b -- a b a )
0238 04               (        forth.asm):00233         nfa_OVER    fcb     4
0239 4F564552         (        forth.asm):00234                     fcc     "OVER"
023D 0222             (        forth.asm):00235         lnk_OVER    fdb     prev_link
023F 0241             (        forth.asm):00236         cfa_OVER    fdb     code_OVER
     0238             (        forth.asm):00237         prev_link   set     nfa_OVER
0241 EC42             (        forth.asm):00238         code_OVER:  ldd     2,u
0243 EDC3             (        forth.asm):00239                     std     ,--u
0245 7E0184           (        forth.asm):00240                     jmp     NEXT
                      (        forth.asm):00241         
                      (        forth.asm):00242                     ; ROT ( a b c -- b c a )
0248 03               (        forth.asm):00243         nfa_ROT     fcb     3
0249 524F54           (        forth.asm):00244                     fcc     "ROT"
024C 0238             (        forth.asm):00245         lnk_ROT     fdb     prev_link
024E 0250             (        forth.asm):00246         cfa_ROT     fdb     code_ROT
     0248             (        forth.asm):00247         prev_link   set     nfa_ROT
0250 EC44             (        forth.asm):00248         code_ROT:   ldd     4,u             ; a
0252 10AE42           (        forth.asm):00249                     ldy     2,u             ; b
0255 10AF44           (        forth.asm):00250                     sty     4,u
0258 10AEC4           (        forth.asm):00251                     ldy     ,u              ; c
025B 10AF42           (        forth.asm):00252                     sty     2,u
025E EDC4             (        forth.asm):00253                     std     ,u
0260 7E0184           (        forth.asm):00254                     jmp     NEXT
                      (        forth.asm):00255         
                      (        forth.asm):00256                     ; >R ( n -- ) ( R: -- n )
0263 02               (        forth.asm):00257         nfa_TOR     fcb     2
0264 3E52             (        forth.asm):00258                     fcc     ">R"
0266 0248             (        forth.asm):00259         lnk_TOR     fdb     prev_link
0268 026A             (        forth.asm):00260         cfa_TOR     fdb     code_TOR
     0263             (        forth.asm):00261         prev_link   set     nfa_TOR
026A ECC1             (        forth.asm):00262         code_TOR:   ldd     ,u++
026C 3406             (        forth.asm):00263                     pshs    d
026E 7E0184           (        forth.asm):00264                     jmp     NEXT
                      (        forth.asm):00265         
                      (        forth.asm):00266                     ; R> ( -- n ) ( R: n -- )
0271 02               (        forth.asm):00267         nfa_RFROM   fcb     2
0272 523E             (        forth.asm):00268                     fcc     "R>"
0274 0263             (        forth.asm):00269         lnk_RFROM   fdb     prev_link
0276 0278             (        forth.asm):00270         cfa_RFROM   fdb     code_RFROM
     0271             (        forth.asm):00271         prev_link   set     nfa_RFROM
0278 3506             (        forth.asm):00272         code_RFROM: puls    d
027A EDC3             (        forth.asm):00273                     std     ,--u
027C 7E0184           (        forth.asm):00274                     jmp     NEXT
                      (        forth.asm):00275         
                      (        forth.asm):00276                     ; R@ ( -- n ) ( R: n -- n )
027F 02               (        forth.asm):00277         nfa_RFETCH  fcb     2
0280 5240             (        forth.asm):00278                     fcc     "R@"
0282 0271             (        forth.asm):00279         lnk_RFETCH  fdb     prev_link
0284 0286             (        forth.asm):00280         cfa_RFETCH  fdb     code_RFETCH
     027F             (        forth.asm):00281         prev_link   set     nfa_RFETCH
0286                  (        forth.asm):00282         code_RFETCH:
