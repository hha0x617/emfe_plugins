0256 10AFC4           (s/forth/forth.asm):00261                     sty     ,u
0259 ED42             (s/forth/forth.asm):00262                     std     2,u
025B 7E0183           (s/forth/forth.asm):00263                     jmp     NEXT
                      (s/forth/forth.asm):00264         
