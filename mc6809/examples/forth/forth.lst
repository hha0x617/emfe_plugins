                      (        forth.asm):00937         ; divmod_core — signed 16/16 → quotient+remainder, used by /, MOD, /MOD.
                      (        forth.asm):00938         ; Entry:  2,U = dividend (a), 0,U = divisor (b)
                      (        forth.asm):00939         ; Exit:   U stack is rewritten as ( rem quot ):   2,U=rem, 0,U=quot
                      (        forth.asm):00940         ;         (a.k.a. -2-slot net push — same cell count as the ( a b ) input)
                      (        forth.asm):00941         ;         U itself is NOT adjusted; callers either return as-is (/MOD) or
                      (        forth.asm):00942         ;         pop one extra cell and overwrite (/, MOD).
                      (        forth.asm):00943         ; Sign rule: truncation toward zero. Quotient sign = sign(a) XOR sign(b).
                      (        forth.asm):00944         ;            Remainder sign follows the dividend (C99 / ANS Forth SM/REM).
                      (        forth.asm):00945         ; Divide-by-zero: leaves rem=a, quot=0 on stack (no trap).
                      (        forth.asm):00946         ; ---------------------------------------------------------------------------
                      (        forth.asm):00947                     ; Scratch. Not DP-based — standard 16-bit addressing.
067F 0000             (        forth.asm):00948         dm_quot     fdb     0               ; quotient accumulator (also shifts dividend in)
0681 0000             (        forth.asm):00949         dm_dvsr     fdb     0               ; absolute divisor
0683 00               (        forth.asm):00950         dm_signq    fcb     0               ; bit7 = quotient sign  (1 = negate at end)
0684 00               (        forth.asm):00951         dm_signr    fcb     0               ; bit7 = remainder sign (1 = negate at end)
                      (        forth.asm):00952         
0685                  (        forth.asm):00953         divmod_core:
0685 ECC4             (        forth.asm):00954                     ldd     ,u              ; D = b
0687 2765             (        forth.asm):00955                     beq     dm_div_by_zero
