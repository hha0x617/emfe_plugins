02B7 A4C4             (        forth.asm):00320                     anda    ,u              ; A &= NOS hi
02B9 E441             (        forth.asm):00321                     andb    1,u             ; B &= NOS lo
02BB EDC4             (        forth.asm):00322                     std     ,u
02BD 7E0184           (        forth.asm):00323                     jmp     NEXT
                      (        forth.asm):00324         
                      (        forth.asm):00325                     ; OR ( a b -- a|b )
02C0 02               (        forth.asm):00326         nfa_OR      fcb     2
02C1 4F52             (        forth.asm):00327                     fcc     "OR"
02C3 02AD             (        forth.asm):00328         lnk_OR      fdb     prev_link
02C5 02C7             (        forth.asm):00329         cfa_OR      fdb     code_OR
     02C0             (        forth.asm):00330         prev_link   set     nfa_OR
