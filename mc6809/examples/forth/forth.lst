06BD 79067F           (        forth.asm):00989                     rol     dm_quot
06C0 59               (        forth.asm):00990                     rolb                    ; remainder <<= 1, bit shifted in from quot
06C1 49               (        forth.asm):00991                     rola
                      (        forth.asm):00992                     ; Trial subtract: if rem >= dvsr, commit subtract and set quot bit 0.
