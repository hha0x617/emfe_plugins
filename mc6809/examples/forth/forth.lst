0687 ECC4             (        forth.asm):00957                     ldd     ,u              ; D = b
0689 2766             (        forth.asm):00958                     beq     dm_div_by_zero
                      (        forth.asm):00959         
                      (        forth.asm):00960                     ; --- take absolute values of a and b, track signs --------------
068B 7F0683           (        forth.asm):00961                     clr     dm_signq
068E 7F0684           (        forth.asm):00962                     clr     dm_signr
0691 EC42             (        forth.asm):00963                     ldd     2,u             ; D = a
0693 2A0D             (        forth.asm):00964                     bpl     dm_a_pos
