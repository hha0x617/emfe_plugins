0696 53               (        forth.asm):00966                     comb
0697 C30001           (        forth.asm):00967                     addd    #1
069A ED42             (        forth.asm):00968                     std     2,u             ; replace a with |a|
069C 730683           (        forth.asm):00969                     com     dm_signq        ; quotient sign: flip
069F 730684           (        forth.asm):00970                     com     dm_signr        ; remainder sign: follows dividend
