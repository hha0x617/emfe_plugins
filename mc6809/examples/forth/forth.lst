06AB 730683           (        forth.asm):00977                     com     dm_signq        ; quotient sign: flip again (XOR)
06AE                  (        forth.asm):00978         dm_b_pos:
06AE FD0681           (        forth.asm):00979                     std     dm_dvsr
                      (        forth.asm):00980         
                      (        forth.asm):00981                     ; --- unsigned 16/16 divide via restoring shift-subtract --------
                      (        forth.asm):00982                     ; [rem:quot] starts as [0:|a|]. 16 iterations: shift left, if the
                      (        forth.asm):00983                     ; 16-bit rem is >= dvsr, subtract and set bit 0 of quot.
06B1 EC42             (        forth.asm):00984                     ldd     2,u             ; |a|
06B3 FD067F           (        forth.asm):00985                     std     dm_quot         ; quot slot starts as dividend
06B6 CC0000           (        forth.asm):00986                     ldd     #0              ; D = remainder
06B9 8E0010           (        forth.asm):00987                     ldx     #16             ; loop counter
