                      (s/forth/forth.asm):00003         ;
                      (s/forth/forth.asm):00004         ; ---------------------------------------------------------------------------
                      (s/forth/forth.asm):00005         ; Hha Forth for MC6809 — ITC (indirect-threaded) kernel running on the
                      (s/forth/forth.asm):00006         ; emfe_plugin_mc6809 environment (MC6850 ACIA at $FF00/$FF01, 64 KB RAM).
                      (s/forth/forth.asm):00007         ;
                      (s/forth/forth.asm):00008         ; Register conventions:
                      (s/forth/forth.asm):00009         ;   U = data stack pointer (grows downward; TOS at  0,U)
                      (s/forth/forth.asm):00010         ;   S = return stack pointer (grows downward; also holds BSR/JSR frames)
                      (s/forth/forth.asm):00011         ;   X = IP                  (points at next CFA word to execute)
                      (s/forth/forth.asm):00012         ;   Y = W                   (holds CFA during NEXT / DOCOL)
                      (s/forth/forth.asm):00013         ;   D = scratch / arithmetic accumulator
                      (s/forth/forth.asm):00014         ;
                      (s/forth/forth.asm):00015         ; Threading (ITC):
                      (s/forth/forth.asm):00016         ;   CFA cell  = pointer to native code (for primitives) or DOCOL (for colon
                      (s/forth/forth.asm):00017         ;               definitions).
                      (s/forth/forth.asm):00018         ;   NEXT does: Y = *IP++; JMP [,Y]   (indirect through Y)
                      (s/forth/forth.asm):00019         ;
                      (s/forth/forth.asm):00020         ; Memory map:
                      (s/forth/forth.asm):00021         ;   $0100..$1FFF   kernel code + built-in dictionary
                      (s/forth/forth.asm):00022         ;   $2000..$9FFF   user dictionary (HERE grows upward)
                      (s/forth/forth.asm):00023         ;   $A000..$A1FF   TIB (terminal input buffer, 512 bytes)
                      (s/forth/forth.asm):00024         ;   $B000..$BFFE   data stack (U starts at $BFFE)
                      (s/forth/forth.asm):00025         ;   $C000..$FEFE   return stack (S starts at $FEFE)
                      (s/forth/forth.asm):00026         ;   $FF00/$FF01    ACIA SR/CR, RDR/TDR
                      (s/forth/forth.asm):00027         ;   $FFFE/$FFFF    reset vector → cold
                      (s/forth/forth.asm):00028         ; ---------------------------------------------------------------------------
                      (s/forth/forth.asm):00029         
                      (s/forth/forth.asm):00030         ; --- equates ---------------------------------------------------------------
     FF00             (s/forth/forth.asm):00031         ACIA_SR     equ     $FF00       ; read: status      write: control
     FF01             (s/forth/forth.asm):00032         ACIA_DATA   equ     $FF01       ; read: RDR         write: TDR
                      (s/forth/forth.asm):00033         
     BFFE             (s/forth/forth.asm):00034         PSP_TOP     equ     $BFFE       ; data stack top (U)
     FEFE             (s/forth/forth.asm):00035         RSP_TOP     equ     $FEFE       ; return stack top (S)
     A000             (s/forth/forth.asm):00036         TIB_ADDR    equ     $A000       ; terminal input buffer
     0200             (s/forth/forth.asm):00037         TIB_SIZE    equ     512
     2800             (s/forth/forth.asm):00038         DICT_START  equ     $2800       ; user dictionary grows from here
                      (s/forth/forth.asm):00039                                         ; (kernel code now exceeds $2000; headroom up to ~$9FFF)
                      (s/forth/forth.asm):00040         
     0080             (s/forth/forth.asm):00041         F_IMMED     equ     $80         ; flags: immediate
     0040             (s/forth/forth.asm):00042         F_HIDDEN    equ     $40         ; flags: hidden (smudge)
     001F             (s/forth/forth.asm):00043         F_LENMASK   equ     $1F         ; low 5 bits = name length (max 31)
                      (s/forth/forth.asm):00044         
                      (s/forth/forth.asm):00045         ; Forth VM entry vector — used by INTERPRET to pass control to a word.
                      (s/forth/forth.asm):00046         ; EXECUTE primitive expects TOS = CFA.
                      (s/forth/forth.asm):00047         
                      (s/forth/forth.asm):00048         ; --- cold-start vector -----------------------------------------------------
                      (s/forth/forth.asm):00049                     org     $0100
0100                  (s/forth/forth.asm):00050         cold:
0100 10CEFEFE         (s/forth/forth.asm):00051                     lds     #RSP_TOP            ; return stack
0104 CEBFFE           (s/forth/forth.asm):00052                     ldu     #PSP_TOP            ; data stack
                      (s/forth/forth.asm):00053                     ; ACIA init: master reset then 8N1 / div-16 / no IRQ.
0107 8603             (s/forth/forth.asm):00054                     lda     #$03
0109 B7FF00           (s/forth/forth.asm):00055                     sta     ACIA_SR
010C 8615             (s/forth/forth.asm):00056                     lda     #$15
010E B7FF00           (s/forth/forth.asm):00057                     sta     ACIA_SR
                      (s/forth/forth.asm):00058         
                      (s/forth/forth.asm):00059                     ; Greeting so the user knows the REPL is alive.
0111 8E0133           (s/forth/forth.asm):00060                     ldx     #msg_ready
0114 8D5F             (s/forth/forth.asm):00061                     bsr     puts_native
                      (s/forth/forth.asm):00062                     ; Seed HERE / LATEST / STATE and sync FORTH's vocab cell.
0116 8E2800           (s/forth/forth.asm):00063                     ldx     #DICT_START
0119 BF110D           (s/forth/forth.asm):00064                     stx     var_HERE
011C 8E21AC           (s/forth/forth.asm):00065                     ldx     #last_builtin_link
011F BF10DA           (s/forth/forth.asm):00066                     stx     var_LATEST           ; live cache
0122 BF214E           (s/forth/forth.asm):00067                     stx     pfa_FORTH_LATEST     ; FORTH vocab's persistent cell
0125 8E0000           (s/forth/forth.asm):00068                     ldx     #0
0128 BF10CD           (s/forth/forth.asm):00069                     stx     var_STATE
                      (s/forth/forth.asm):00070                     ; Enter the Forth VM: IP → boot_code → cfa_QUIT → DOCOL → QUIT body.
012B 8E0131           (s/forth/forth.asm):00071                     ldx     #boot_code
012E 7E0186           (s/forth/forth.asm):00072                     jmp     NEXT
                      (s/forth/forth.asm):00073         
0131 210E             (s/forth/forth.asm):00074         boot_code:  fdb     cfa_QUIT
                      (s/forth/forth.asm):00075         
0133 48686120466F7274 (s/forth/forth.asm):00076         msg_ready   fcc     "Hha Forth for MC6809 ready."
     6820666F72204D43
     3638303920726561
     64792E
014E 0D0A             (s/forth/forth.asm):00077                     fcb     $0D,$0A
0150 2863292032303236 (s/forth/forth.asm):00078                     fcc     "(c) 2026 hha0x617 - MIT/Apache-2.0"
     2068686130783631
     37202D204D49542F
     4170616368652D32
     2E30
0172 0D0A00           (s/forth/forth.asm):00079                     fcb     $0D,$0A,0
                      (s/forth/forth.asm):00080         
                      (s/forth/forth.asm):00081         ; Native puts: X -> NUL-terminated string. Uses A, B; preserves X? no,
                      (s/forth/forth.asm):00082         ; destroys X. Used during cold boot only.
0175                  (s/forth/forth.asm):00083         puts_native:
0175 A680             (s/forth/forth.asm):00084                     lda     ,x+
0177 270C             (s/forth/forth.asm):00085                     beq     puts_done
0179 F6FF00           (s/forth/forth.asm):00086         puts_wait:  ldb     ACIA_SR
017C C502             (s/forth/forth.asm):00087                     bitb    #$02
017E 27F9             (s/forth/forth.asm):00088                     beq     puts_wait
0180 B7FF01           (s/forth/forth.asm):00089                     sta     ACIA_DATA
0183 20F0             (s/forth/forth.asm):00090                     bra     puts_native
0185                  (s/forth/forth.asm):00091         puts_done:
0185 39               (s/forth/forth.asm):00092                     rts
                      (s/forth/forth.asm):00093         
                      (s/forth/forth.asm):00094         ; ---------------------------------------------------------------------------
                      (s/forth/forth.asm):00095         ; Inner interpreter — NEXT / DOCOL / EXIT
                      (s/forth/forth.asm):00096         ; ---------------------------------------------------------------------------
0186                  (s/forth/forth.asm):00097         NEXT:
0186 10AE81           (s/forth/forth.asm):00098                     ldy     ,x++            ; W = *IP; IP += 2
0189 6EB4             (s/forth/forth.asm):00099                     jmp     [,y]            ; jump through CFA → code field's code
                      (s/forth/forth.asm):00100         
                      (s/forth/forth.asm):00101         ; DOCOL: enter a colon definition. Called via NEXT when the CFA's contents
                      (s/forth/forth.asm):00102         ; point here. On entry Y = CFA; the body starts at Y+2.
018B                  (s/forth/forth.asm):00103         DOCOL:
018B 3410             (s/forth/forth.asm):00104                     pshs    x               ; push old IP onto return stack
018D 3022             (s/forth/forth.asm):00105                     leax    2,y             ; IP = CFA + 2 (body address)
018F 7E0186           (s/forth/forth.asm):00106                     jmp     NEXT
                      (s/forth/forth.asm):00107         
                      (s/forth/forth.asm):00108         ; DOVAR: code field for VARIABLE. Pushes PFA onto the data stack.
0192                  (s/forth/forth.asm):00109         DOVAR:
0192 3122             (s/forth/forth.asm):00110                     leay    2,y             ; PFA = CFA + 2
0194 10AFC3           (s/forth/forth.asm):00111                     sty     ,--u            ; push PFA as 16-bit cell
0197 7E0186           (s/forth/forth.asm):00112                     jmp     NEXT
                      (s/forth/forth.asm):00113         
                      (s/forth/forth.asm):00114         ; DOCON: code field for CONSTANT. Pushes *PFA onto the data stack.
019A                  (s/forth/forth.asm):00115         DOCON:
019A EC22             (s/forth/forth.asm):00116                     ldd     2,y             ; D = value stored at PFA
019C EDC3             (s/forth/forth.asm):00117                     std     ,--u
019E 7E0186           (s/forth/forth.asm):00118                     jmp     NEXT
                      (s/forth/forth.asm):00119         
                      (s/forth/forth.asm):00120         ; DOCREATE: code field for CREATE-d words.  Body layout:
                      (s/forth/forth.asm):00121         ;   CFA+0  → DOCREATE (here)
                      (s/forth/forth.asm):00122         ;   CFA+2  → DOES_ADDR (0 if no DOES>, else address of runtime code)
                      (s/forth/forth.asm):00123         ;   CFA+4  → PFA (user data from ALLOT)
                      (s/forth/forth.asm):00124         ; If DOES_ADDR == 0, push PFA and continue.
                      (s/forth/forth.asm):00125         ; Otherwise push PFA, save caller's IP, and enter the runtime code.
01A1                  (s/forth/forth.asm):00126         DOCREATE:
01A1 EC22             (s/forth/forth.asm):00127                     ldd     2,y             ; D = DOES_ADDR
01A3 270C             (s/forth/forth.asm):00128                     beq     docr_no_does
                      (s/forth/forth.asm):00129                     ; Has DOES> runtime.  Save IP, replace with DOES_ADDR, push PFA.
01A5 3410             (s/forth/forth.asm):00130                     pshs    x               ; save caller's IP on the return stack
01A7 1F01             (s/forth/forth.asm):00131                     tfr     d,x             ; X = DOES_ADDR (new IP)
01A9 3124             (s/forth/forth.asm):00132                     leay    4,y             ; Y = PFA
01AB 10AFC3           (s/forth/forth.asm):00133                     sty     ,--u
01AE 7E0186           (s/forth/forth.asm):00134                     jmp     NEXT
01B1                  (s/forth/forth.asm):00135         docr_no_does:
01B1 3124             (s/forth/forth.asm):00136                     leay    4,y             ; Y = PFA
01B3 10AFC3           (s/forth/forth.asm):00137                     sty     ,--u
01B6 7E0186           (s/forth/forth.asm):00138                     jmp     NEXT
                      (s/forth/forth.asm):00139         
                      (s/forth/forth.asm):00140         ; DOMARKER: code field for MARKER-created words.  PFA layout:
                      (s/forth/forth.asm):00141         ;   PFA+0 : saved LATEST (2 bytes)
                      (s/forth/forth.asm):00142         ;   PFA+2 : saved HERE   (2 bytes)
                      (s/forth/forth.asm):00143         ; Executing the marker restores both, effectively forgetting everything
                      (s/forth/forth.asm):00144         ; defined after (and including) the marker itself.
01B9                  (s/forth/forth.asm):00145         DOMARKER:
01B9 3122             (s/forth/forth.asm):00146                     leay    2,y             ; Y = PFA
01BB ECA4             (s/forth/forth.asm):00147                     ldd     ,y              ; saved LATEST
01BD FD10DA           (s/forth/forth.asm):00148                     std     var_LATEST
01C0 EC22             (s/forth/forth.asm):00149                     ldd     2,y             ; saved HERE
01C2 FD110D           (s/forth/forth.asm):00150                     std     var_HERE
01C5 7E0186           (s/forth/forth.asm):00151                     jmp     NEXT
                      (s/forth/forth.asm):00152         
                      (s/forth/forth.asm):00153         ; DOVOC: code field for VOCABULARY-created words.  PFA layout:
                      (s/forth/forth.asm):00154         ;   PFA+0 : latest NFA in this vocabulary (0 = empty)
                      (s/forth/forth.asm):00155         ;   PFA+2 : parent-vocab's PFA+0 address (0 = root)
                      (s/forth/forth.asm):00156         ; Executing a vocab switches the active search/define namespace to it.
                      (s/forth/forth.asm):00157         ; Before switching, var_LATEST (the cache) is flushed back to the OLD
                      (s/forth/forth.asm):00158         ; vocab's PFA+0; then the NEW vocab's PFA+0 is loaded into var_LATEST.
01C8                  (s/forth/forth.asm):00159         DOVOC:
01C8 3122             (s/forth/forth.asm):00160                     leay    2,y                  ; Y = new vocab's PFA+0
01CA BE110F           (s/forth/forth.asm):00161                     ldx     var_LATEST_PTR       ; X = old vocab's PFA+0
01CD FC10DA           (s/forth/forth.asm):00162                     ldd     var_LATEST
01D0 ED84             (s/forth/forth.asm):00163                     std     ,x                   ; flush cache to old vocab
01D2 10BF110F         (s/forth/forth.asm):00164                     sty     var_LATEST_PTR
01D6 ECA4             (s/forth/forth.asm):00165                     ldd     ,y                   ; load new vocab's latest
01D8 FD10DA           (s/forth/forth.asm):00166                     std     var_LATEST
01DB 7E0186           (s/forth/forth.asm):00167                     jmp     NEXT
                      (s/forth/forth.asm):00168         
                      (s/forth/forth.asm):00169         ; ---------------------------------------------------------------------------
                      (s/forth/forth.asm):00170         ; Built-in dictionary — linked list grows from `last_builtin_link`, each
                      (s/forth/forth.asm):00171         ; entry has:
                      (s/forth/forth.asm):00172         ;
                      (s/forth/forth.asm):00173         ;     +0  flags+length byte
                      (s/forth/forth.asm):00174         ;     +1  name bytes (len bytes)
                      (s/forth/forth.asm):00175         ;     +N  link field (2 bytes, big-endian — pointer to previous entry's
                      (s/forth/forth.asm):00176         ;         flags byte, i.e. NFA of previous word)
                      (s/forth/forth.asm):00177         ;     +N+2  CFA  (2 bytes — for primitives: address of code;
                      (s/forth/forth.asm):00178         ;                        for colon defs: address of DOCOL)
                      (s/forth/forth.asm):00179         ;     +N+4  PFA  (body — only for non-primitives)
                      (s/forth/forth.asm):00180         ;
                      (s/forth/forth.asm):00181         ; The `WORD` macro below lays out a primitive header. A secondary macro lays
                      (s/forth/forth.asm):00182         ; out a colon definition header.
                      (s/forth/forth.asm):00183         ; ---------------------------------------------------------------------------
                      (s/forth/forth.asm):00184         
                      (s/forth/forth.asm):00185         ; Each primitive's header starts with a label for the flags/length byte
                      (s/forth/forth.asm):00186         ; (the NFA), followed by name+link+CFA. We emit them with inline .fcb/.fdb.
                      (s/forth/forth.asm):00187         
                      (s/forth/forth.asm):00188         ; link anchor: NULL terminator at the bottom of the chain
     0000             (s/forth/forth.asm):00189         prev_link   set     0
                      (s/forth/forth.asm):00190         
                      (s/forth/forth.asm):00191                     ; -- primitive: EXIT ( -- )  restore IP from R stack ------------
01DE 04               (s/forth/forth.asm):00192         nfa_EXIT    fcb     4
01DF 45584954         (s/forth/forth.asm):00193                     fcc     "EXIT"
01E3 0000             (s/forth/forth.asm):00194         lnk_EXIT    fdb     prev_link
01E5 01E7             (s/forth/forth.asm):00195         cfa_EXIT    fdb     code_EXIT
     01DE             (s/forth/forth.asm):00196         prev_link   set     nfa_EXIT
                      (s/forth/forth.asm):00197         
01E7 3510             (s/forth/forth.asm):00198         code_EXIT:  puls    x               ; IP = saved IP
01E9 7E0186           (s/forth/forth.asm):00199                     jmp     NEXT
                      (s/forth/forth.asm):00200         
                      (s/forth/forth.asm):00201                     ; -- primitive: (LIT) — inline literal --------------------------
01EC 05               (s/forth/forth.asm):00202         nfa_LIT     fcb     5
01ED 284C495429       (s/forth/forth.asm):00203                     fcc     "(LIT)"
01F2 01DE             (s/forth/forth.asm):00204         lnk_LIT     fdb     prev_link
01F4 01F6             (s/forth/forth.asm):00205         cfa_LIT     fdb     code_LIT
     01EC             (s/forth/forth.asm):00206         prev_link   set     nfa_LIT
                      (s/forth/forth.asm):00207         
01F6 EC81             (s/forth/forth.asm):00208         code_LIT:   ldd     ,x++            ; D = *IP++; IP advanced past the cell
01F8 EDC3             (s/forth/forth.asm):00209                     std     ,--u
01FA 7E0186           (s/forth/forth.asm):00210                     jmp     NEXT
                      (s/forth/forth.asm):00211         
                      (s/forth/forth.asm):00212                     ; -- primitive: (0BRANCH) — branch if TOS == 0 ------------------
01FD 09               (s/forth/forth.asm):00213         nfa_0BR     fcb     9
01FE 28304252414E4348 (s/forth/forth.asm):00214                     fcc     "(0BRANCH)"
     29
0207 01EC             (s/forth/forth.asm):00215         lnk_0BR     fdb     prev_link
0209 020B             (s/forth/forth.asm):00216         cfa_0BR     fdb     code_0BR
     01FD             (s/forth/forth.asm):00217         prev_link   set     nfa_0BR
                      (s/forth/forth.asm):00218         
020B ECC1             (s/forth/forth.asm):00219         code_0BR:   ldd     ,u++            ; pop condition
020D 10830000         (s/forth/forth.asm):00220                     cmpd    #0
0211 2705             (s/forth/forth.asm):00221                     beq     take_0br
0213 3002             (s/forth/forth.asm):00222                     leax    2,x             ; skip offset, don't branch
0215 7E0186           (s/forth/forth.asm):00223                     jmp     NEXT
0218 EC84             (s/forth/forth.asm):00224         take_0br:   ldd     ,x              ; D = branch offset (signed, cell-relative)
021A 308B             (s/forth/forth.asm):00225                     leax    d,x             ; IP += offset
021C 7E0186           (s/forth/forth.asm):00226                     jmp     NEXT
                      (s/forth/forth.asm):00227         
                      (s/forth/forth.asm):00228                     ; -- primitive: (BRANCH) — unconditional branch -----------------
021F 08               (s/forth/forth.asm):00229         nfa_BR      fcb     8
0220 284252414E434829 (s/forth/forth.asm):00230                     fcc     "(BRANCH)"
0228 01FD             (s/forth/forth.asm):00231         lnk_BR      fdb     prev_link
022A 022C             (s/forth/forth.asm):00232         cfa_BR      fdb     code_BR
     021F             (s/forth/forth.asm):00233         prev_link   set     nfa_BR
                      (s/forth/forth.asm):00234         
022C EC84             (s/forth/forth.asm):00235         code_BR:    ldd     ,x
022E 308B             (s/forth/forth.asm):00236                     leax    d,x
0230 7E0186           (s/forth/forth.asm):00237                     jmp     NEXT
                      (s/forth/forth.asm):00238         
                      (s/forth/forth.asm):00239                     ; -- primitive: EXECUTE ( xt -- ) -------------------------------
0233 07               (s/forth/forth.asm):00240         nfa_EXEC    fcb     7
0234 45584543555445   (s/forth/forth.asm):00241                     fcc     "EXECUTE"
023B 021F             (s/forth/forth.asm):00242         lnk_EXEC    fdb     prev_link
023D 023F             (s/forth/forth.asm):00243         cfa_EXEC    fdb     code_EXEC
     0233             (s/forth/forth.asm):00244         prev_link   set     nfa_EXEC
                      (s/forth/forth.asm):00245         
023F 10AEC1           (s/forth/forth.asm):00246         code_EXEC:  ldy     ,u++            ; Y = CFA popped from data stack
0242 6EB4             (s/forth/forth.asm):00247                     jmp     [,y]
                      (s/forth/forth.asm):00248         
                      (s/forth/forth.asm):00249         ; ---------------------------------------------------------------------------
                      (s/forth/forth.asm):00250         ; Stack primitives
                      (s/forth/forth.asm):00251         ; ---------------------------------------------------------------------------
                      (s/forth/forth.asm):00252                     ; DUP ( a -- a a )
0244 03               (s/forth/forth.asm):00253         nfa_DUP     fcb     3
0245 445550           (s/forth/forth.asm):00254                     fcc     "DUP"
0248 0233             (s/forth/forth.asm):00255         lnk_DUP     fdb     prev_link
024A 024C             (s/forth/forth.asm):00256         cfa_DUP     fdb     code_DUP
     0244             (s/forth/forth.asm):00257         prev_link   set     nfa_DUP
024C ECC4             (s/forth/forth.asm):00258         code_DUP:   ldd     ,u
024E EDC3             (s/forth/forth.asm):00259                     std     ,--u
0250 7E0186           (s/forth/forth.asm):00260                     jmp     NEXT
                      (s/forth/forth.asm):00261         
                      (s/forth/forth.asm):00262                     ; DROP ( a -- )
0253 04               (s/forth/forth.asm):00263         nfa_DROP    fcb     4
0254 44524F50         (s/forth/forth.asm):00264                     fcc     "DROP"
0258 0244             (s/forth/forth.asm):00265         lnk_DROP    fdb     prev_link
025A 025C             (s/forth/forth.asm):00266         cfa_DROP    fdb     code_DROP
     0253             (s/forth/forth.asm):00267         prev_link   set     nfa_DROP
025C 3342             (s/forth/forth.asm):00268         code_DROP:  leau    2,u
025E 7E0186           (s/forth/forth.asm):00269                     jmp     NEXT
                      (s/forth/forth.asm):00270         
                      (s/forth/forth.asm):00271                     ; SWAP ( a b -- b a )
0261 04               (s/forth/forth.asm):00272         nfa_SWAP    fcb     4
0262 53574150         (s/forth/forth.asm):00273                     fcc     "SWAP"
0266 0253             (s/forth/forth.asm):00274         lnk_SWAP    fdb     prev_link
0268 026A             (s/forth/forth.asm):00275         cfa_SWAP    fdb     code_SWAP
     0261             (s/forth/forth.asm):00276         prev_link   set     nfa_SWAP
026A ECC4             (s/forth/forth.asm):00277         code_SWAP:  ldd     ,u
026C 10AE42           (s/forth/forth.asm):00278                     ldy     2,u
026F 10AFC4           (s/forth/forth.asm):00279                     sty     ,u
0272 ED42             (s/forth/forth.asm):00280                     std     2,u
0274 7E0186           (s/forth/forth.asm):00281                     jmp     NEXT
                      (s/forth/forth.asm):00282         
                      (s/forth/forth.asm):00283                     ; OVER ( a b -- a b a )
0277 04               (s/forth/forth.asm):00284         nfa_OVER    fcb     4
0278 4F564552         (s/forth/forth.asm):00285                     fcc     "OVER"
027C 0261             (s/forth/forth.asm):00286         lnk_OVER    fdb     prev_link
027E 0280             (s/forth/forth.asm):00287         cfa_OVER    fdb     code_OVER
     0277             (s/forth/forth.asm):00288         prev_link   set     nfa_OVER
0280 EC42             (s/forth/forth.asm):00289         code_OVER:  ldd     2,u
0282 EDC3             (s/forth/forth.asm):00290                     std     ,--u
0284 7E0186           (s/forth/forth.asm):00291                     jmp     NEXT
                      (s/forth/forth.asm):00292         
                      (s/forth/forth.asm):00293                     ; ROT ( a b c -- b c a )
