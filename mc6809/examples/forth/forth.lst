06AC                  (        forth.asm):00975         dm_b_pos:
06AC FD0681           (        forth.asm):00976                     std     dm_dvsr
                      (        forth.asm):00977         
                      (        forth.asm):00978                     ; --- unsigned 16/16 divide via restoring shift-subtract --------
                      (        forth.asm):00979                     ; [rem:quot] starts as [0:|a|]. 16 iterations: shift left, if the
                      (        forth.asm):00980                     ; 16-bit rem is >= dvsr, subtract and set bit 0 of quot.
06AF EC42             (        forth.asm):00981                     ldd     2,u             ; |a|
06B1 FD067F           (        forth.asm):00982                     std     dm_quot         ; quot slot starts as dividend
06B4 CC0000           (        forth.asm):00983                     ldd     #0              ; D = remainder
06B7 8E0010           (        forth.asm):00984                     ldx     #16             ; loop counter
06BA                  (        forth.asm):00985         dm_loop:
                      (        forth.asm):00986                     ; Shift quot left 1, carry-out into LSB of remainder.
                      (        forth.asm):00987                     ; We do it on the in-memory quot so we can use ROL directly.
